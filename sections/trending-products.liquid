<style>
  .trending-products {
    padding: var(--space-md) 0 var(--space-2xl);
    max-width: var(--page-max-width);
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .trending-products {
      padding: var(--space-sm) 0 var(--space-xl);
    }
  }

  .trending-products__heading {
    margin-bottom: var(--space-md);
    padding: 0 var(--page-padding);
  }

  .trending-products__carousel {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .trending-products__carousel::-webkit-scrollbar {
    display: none;
  }

  .trending-products__card {
    flex: 0 0 25%;
    scroll-snap-align: start;
    min-width: 250px;
  }

  @media (max-width: 768px) {
    .trending-products__card {
      flex: 0 0 65%;
      min-width: 200px;
    }
  }

  .trending-products__nav {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: var(--space-sm);
    padding: 0 var(--page-padding);
  }

  .trending-products__nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
  }

  .trending-products__nav-btn:hover {
    border-color: var(--color-text);
  }

  .trending-products__nav-btn svg {
    width: 12px;
    height: 12px;
  }
</style>

<section class="trending-products reveal">
  <h2 class="heading-2 trending-products__heading">{{ section.settings.heading | default: 'Top 15 Trending Products' }}</h2>

  <div class="trending-products__carousel" id="trending-carousel">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection != blank -%}
      {%- for product in collection.products limit: section.settings.limit -%}
        <div class="trending-products__card">
          {% render 'product-card', product: product %}
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..8) -%}
        <div class="trending-products__card">
          <div class="product-card">
            <div class="product-card__bordered">
              <div class="product-card__image-wrapper"></div>
              <button class="product-card__quick-add">ADD +</button>
            </div>
            <div class="product-card__info">
              <span class="product-card__name">Product Name</span>
              <div class="product-card__price">$499</div>
              <div class="product-card__meta">
                <div class="product-card__swatches">
                  <span class="product-card__swatch product-card__swatch--silver"></span>
                </div>
                <span class="product-card__material">Sterling Silver, Moissanite</span>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="trending-products__nav">
    <button class="trending-products__nav-btn" aria-label="Previous" onclick="document.getElementById('trending-carousel').scrollBy({left:-300,behavior:'smooth'})">
      <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="8,2 4,6 8,10"></polyline></svg>
    </button>
    <button class="trending-products__nav-btn" aria-label="Next" onclick="document.getElementById('trending-carousel').scrollBy({left:300,behavior:'smooth'})">
      <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4,2 8,6 4,10"></polyline></svg>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Trending Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top 15 Trending Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Trending Products"
    }
  ]
}
{% endschema %}
