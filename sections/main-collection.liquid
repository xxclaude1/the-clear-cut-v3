<style>
  .collection-page {
    padding: var(--space-md) var(--page-padding) var(--space-2xl);
    max-width: var(--page-max-width);
    margin: 0 auto;
  }

  .collection-page__title {
    margin-bottom: var(--space-md);
  }

  .collection-page__description {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 600px;
  }

  /* Category image bar */
  .collection-page__categories {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    margin-bottom: var(--space-md);
    padding-bottom: 4px;
  }

  .collection-page__categories::-webkit-scrollbar { display: none; }

  .collection-page__cat-item {
    flex-shrink: 0;
    position: relative;
    width: 120px;
    overflow: hidden;
    display: block;
  }

  .collection-page__cat-image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    background-color: var(--color-bg-warm);
    display: block;
    transition: transform 400ms ease;
  }

  .collection-page__cat-item:hover .collection-page__cat-image {
    transform: scale(1.05);
  }

  .collection-page__cat-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 8px;
    background: linear-gradient(transparent, rgba(0,0,0,0.5));
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: white;
  }

  /* Filter bar */
  .collection-page__filters {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
    gap: 12px;
  }

  .collection-page__filter-left {
    display: flex;
    gap: 16px;
  }

  .collection-page__filter-btn {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 0;
    transition: opacity var(--duration-fast) ease;
  }

  .collection-page__filter-btn:hover {
    opacity: 0.6;
  }

  .collection-page__filter-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .collection-page__count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .collection-page__sort {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-text);
    padding: 8px 12px;
    appearance: none;
  }

  .collection-page__sort:focus {
    border-color: var(--color-border-dark);
    outline: none;
  }

  /* Empty state */
  .collection-page__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 0;
    color: var(--color-text-secondary);
  }

  /* Pagination */
  .collection-page__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .collection-page__pagination a,
  .collection-page__pagination span {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    padding: 8px 14px;
    border: 1px solid var(--color-border);
    transition: background-color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .collection-page__pagination a:hover {
    border-color: var(--color-text);
  }

  .collection-page__pagination .is-current {
    background-color: var(--color-text);
    color: var(--color-btn-primary-text);
    border-color: var(--color-text);
  }
</style>

<div class="collection-page">
  <h1 class="heading-1 collection-page__title">{{ collection.title | default: 'Shop All' }}</h1>

  {%- if collection.description != blank -%}
    <p class="collection-page__description">{{ collection.description }}</p>
  {%- endif -%}

  <!-- Category image bar -->
  <div class="collection-page__categories">
    <a href="/collections/all" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Shop All</span>
    </a>
    <a href="/collections/bracelets" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Bracelets</span>
    </a>
    <a href="/collections/earrings" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Earrings</span>
    </a>
    <a href="/collections/rings" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Rings</span>
    </a>
    <a href="/collections/necklaces" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Necklaces</span>
    </a>
    <a href="/collections/tennis-jewelry" class="collection-page__cat-item">
      <div class="collection-page__cat-image"></div>
      <span class="collection-page__cat-label">Tennis</span>
    </a>
  </div>

  <!-- Filter bar -->
  <div class="collection-page__filters">
    <div class="collection-page__filter-left">
      <button class="collection-page__filter-btn">Category</button>
      <button class="collection-page__filter-btn">Material</button>
      <button class="collection-page__filter-btn">All Filters</button>
    </div>
    <div class="collection-page__filter-right">
      <span class="collection-page__count">({{ collection.products_count | default: 0 }} Products)</span>
      <select class="collection-page__sort" id="collection-sort" aria-label="Sort products">
        <option value="best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>Best Selling</option>
        <option value="title-ascending"{% if collection.sort_by == 'title-ascending' %} selected{% endif %}>A to Z</option>
        <option value="title-descending"{% if collection.sort_by == 'title-descending' %} selected{% endif %}>Z to A</option>
        <option value="price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Price: Low to High</option>
        <option value="price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Price: High to Low</option>
        <option value="created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>Newest</option>
      </select>
    </div>
  </div>

  <!-- Product grid -->
  <div class="product-grid">
    {%- paginate collection.products by 24 -%}
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <div class="collection-page__empty">
          <p class="body-text">No products found in this collection.</p>
        </div>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <div class="collection-page__pagination" style="grid-column: 1 / -1;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">Previous</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="is-current">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">Next</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

<script>
  document.getElementById('collection-sort').addEventListener('change', function() {
    var url = new URL(window.location.href);
    url.searchParams.set('sort_by', this.value);
    window.location.href = url.toString();
  });
</script>

{% schema %}
{
  "name": "Main Collection",
  "settings": []
}
{% endschema %}
