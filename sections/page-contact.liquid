<style>
  .contact-page { max-width: 720px; margin: 0 auto; padding: 0 var(--page-padding); }
  .contact-page__hero { text-align: center; padding: var(--space-2xl) 0 var(--space-xl); }
  .contact-page__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-secondary); margin-bottom: var(--space-sm); }
  .contact-page__heading { font-family: var(--font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 400; color: var(--color-text); line-height: 1.2; margin-bottom: var(--space-sm); }
  .contact-page__sub { font-family: var(--font-body); font-size: 15px; color: var(--color-text-secondary); line-height: 1.7; }

  .contact-page__grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-md); padding: var(--space-lg) 0 var(--space-xl); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-xl); }
  .contact-page__card { text-align: center; padding: var(--space-lg) var(--space-sm); background-color: var(--color-bg-warm); }
  .contact-page__card-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: var(--space-xs); }
  .contact-page__card-value { font-family: var(--font-body); font-size: 14px; font-weight: 500; color: var(--color-text); margin-bottom: 4px; }
  .contact-page__card-detail { font-family: var(--font-body); font-size: 13px; color: var(--color-text-secondary); line-height: 1.6; }

  .contact-page__form-heading { font-family: var(--font-display); font-size: 24px; font-weight: 400; color: var(--color-text); text-align: center; margin-bottom: var(--space-xs); }
  .contact-page__form-sub { font-family: var(--font-body); font-size: 14px; color: var(--color-text-secondary); text-align: center; margin-bottom: var(--space-lg); }

  .contact-page__form { display: flex; flex-direction: column; gap: var(--space-sm); margin-bottom: var(--space-2xl); }
  .contact-page__field-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-sm); }
  .contact-page__field { display: flex; flex-direction: column; gap: 6px; }
  .contact-page__field-label { font-family: var(--font-body); font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text); }
  .contact-page__input, .contact-page__textarea { font-family: var(--font-body); font-size: 14px; color: var(--color-text); padding: 12px 16px; border: 1px solid var(--color-border); background-color: var(--color-bg); transition: border-color var(--duration-fast) ease; -webkit-appearance: none; border-radius: 0; }
  .contact-page__input:focus, .contact-page__textarea:focus { outline: none; border-color: var(--color-text); }
  .contact-page__input::placeholder, .contact-page__textarea::placeholder { color: var(--color-text-muted); }
  .contact-page__textarea { min-height: 120px; resize: vertical; }
  .contact-page__submit { display: inline-block; font-family: var(--font-body); font-weight: 500; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-btn-primary-text); background-color: var(--color-btn-primary-bg); border: none; padding: 16px 40px; cursor: pointer; transition: background-color var(--duration-fast) ease; align-self: flex-start; }
  .contact-page__submit:hover { background-color: var(--color-btn-primary-hover); }

  @media (max-width: 768px) { .contact-page__grid { grid-template-columns: 1fr; } .contact-page__field-row { grid-template-columns: 1fr; } }
</style>

<div class="contact-page">
  <div class="contact-page__hero reveal">
    <div class="contact-page__label">Get in Touch</div>
    <h1 class="contact-page__heading">Contact Us</h1>
    <p class="contact-page__sub">We would love to hear from you. Our team responds to every enquiry within 24 hours.</p>
  </div>

  <div class="contact-page__grid reveal">
    <div class="contact-page__card">
      <div class="contact-page__card-label">Email</div>
      <div class="contact-page__card-value">hello@theclearcut.au</div>
      <div class="contact-page__card-detail">24-hour response time</div>
    </div>
    <div class="contact-page__card">
      <div class="contact-page__card-label">Hours</div>
      <div class="contact-page__card-value">Mon – Fri</div>
      <div class="contact-page__card-detail">9:00 AM – 5:00 PM AEST</div>
    </div>
    <div class="contact-page__card">
      <div class="contact-page__card-label">Location</div>
      <div class="contact-page__card-value">Australia</div>
      <div class="contact-page__card-detail">Online only</div>
    </div>
  </div>

  <h2 class="contact-page__form-heading reveal">Send Us a Message</h2>
  <p class="contact-page__form-sub reveal">Questions about an order, sizing, or anything else — we are here to help.</p>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <p style="text-align:center; font-family:var(--font-body); font-size:15px; color:var(--color-text); padding:var(--space-lg) 0 var(--space-2xl);">Thank you for your message. We will get back to you within 24 hours.</p>
    {% else %}
      <div class="contact-page__form reveal">
        <div class="contact-page__field-row">
          <div class="contact-page__field">
            <label class="contact-page__field-label" for="contact-name">Name *</label>
            <input class="contact-page__input" type="text" id="contact-name" name="contact[name]" placeholder="Your name" required>
          </div>
          <div class="contact-page__field">
            <label class="contact-page__field-label" for="contact-email">Email *</label>
            <input class="contact-page__input" type="email" id="contact-email" name="contact[email]" placeholder="you@email.com" required>
          </div>
        </div>
        <div class="contact-page__field">
          <label class="contact-page__field-label" for="contact-subject">Subject</label>
          <input class="contact-page__input" type="text" id="contact-subject" name="contact[subject]" placeholder="Order enquiry, sizing help, general question...">
        </div>
        <div class="contact-page__field">
          <label class="contact-page__field-label" for="contact-message">Message *</label>
          <textarea class="contact-page__textarea" id="contact-message" name="contact[body]" placeholder="How can we help?" required></textarea>
        </div>
        <button type="submit" class="contact-page__submit">Send Message</button>
      </div>
    {% endif %}
  {% endform %}
</div>

{% schema %}
{ "name": "Contact Page", "settings": [] }
{% endschema %}
