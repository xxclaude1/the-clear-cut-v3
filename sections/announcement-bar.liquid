<style>
  .announcement-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--announcement-height);
    background-color: var(--color-announcement-bg);
    color: var(--color-announcement-text);
    z-index: 110;
    overflow: hidden;
  }

  .announcement-bar__messages {
    position: relative;
    text-align: center;
    width: 100%;
    height: 100%;
  }

  .announcement-bar__message {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.02em;
    opacity: 0;
    transition: opacity 400ms ease;
    padding: 0 40px;
  }

  @media (max-width: 768px) {
    .announcement-bar__message {
      font-size: 11px;
    }
  }

  .announcement-bar__message.is-active {
    opacity: 1;
  }

  .announcement-bar__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--color-announcement-text);
    cursor: pointer;
    padding: 8px;
    z-index: 2;
    opacity: 0.7;
    transition: opacity var(--duration-fast) ease;
  }

  .announcement-bar__nav:hover {
    opacity: 1;
  }

  .announcement-bar__prev {
    left: 12px;
  }

  .announcement-bar__next {
    right: 12px;
  }

  .announcement-bar__nav svg {
    width: 10px;
    height: 10px;
  }
</style>

<div class="announcement-bar" role="region" aria-label="Announcements">
  <button class="announcement-bar__nav announcement-bar__prev" aria-label="Previous announcement">
    <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="7,1 3,5 7,9"></polyline>
    </svg>
  </button>

  <div class="announcement-bar__messages">
    {%- for block in section.blocks -%}
      <div class="announcement-bar__message{% if forloop.first %} is-active{% endif %}">
        {{ block.settings.text }}
      </div>
    {%- endfor -%}
  </div>

  <button class="announcement-bar__nav announcement-bar__next" aria-label="Next announcement">
    <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="3,1 7,5 3,9"></polyline>
    </svg>
  </button>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message text",
          "default": "Free Express Shipping Australia-Wide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free Express Shipping Australia-Wide" } },
        { "type": "message", "settings": { "text": "30-Day Returns On All Orders" } },
        { "type": "message", "settings": { "text": "Lifetime Warranty Included" } }
      ]
    }
  ]
}
{% endschema %}
