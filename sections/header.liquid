<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: transparent;
    transition: background-color var(--duration-normal) ease, box-shadow var(--duration-fast) ease;
  }

  .header--scrolled {
    background-color: var(--color-bg);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }

  /* ---- Desktop header ---- */
  .header__inner {
    display: flex;
    align-items: center;
    height: var(--header-height);
    padding: 0 var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
    gap: 32px;
  }

  /* Left — Logo */
  .header__logo {
    flex-shrink: 0;
  }

  .header__logo a {
    display: block;
  }

  .header__logo-img {
    height: 18px;
    width: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .header__logo-img {
      height: 14px;
    }
  }

  /* Center — Nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    transition: opacity var(--duration-fast) ease;
    line-height: 1;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    white-space: nowrap;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    opacity: 0.6;
  }

  .header__nav-link.is-active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Right — Icons */
  .header__icons {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .header__icon-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    transition: opacity var(--duration-fast) ease;
    padding: 0;
  }

  .header__icon-btn:hover {
    opacity: 0.6;
  }

  .header__icon-btn svg {
    width: 20px;
    height: 20px;
  }

  .header__search-btn {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__search-input-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
  }

  .header__search-input-wrap svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .header__search-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Cart count badge */
  .header__cart-btn {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-text);
    color: var(--color-btn-primary-text);
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    border-radius: 50%;
    padding: 0 4px;
    line-height: 1;
  }

  .header__cart-count:empty {
    display: none;
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 20px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__hamburger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-text);
  }

  /* ============================================
     MOBILE HEADER — hamburger LEFT, logo CENTER, icons RIGHT
     ============================================ */
  @media (max-width: 768px) {
    .header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-areas: "left center right";
      align-items: center;
      gap: 0;
    }

    .header__mobile-left {
      grid-area: left;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .header__logo {
      grid-area: center;
      display: flex;
      justify-content: center;
    }

    .header__icons {
      grid-area: right;
      justify-content: flex-end;
      gap: 16px;
    }

    /* Hide desktop nav on mobile */
    .header__nav {
      display: none;
    }
  }

  @media (min-width: 769px) {
    .header__mobile-left {
      display: none;
    }
  }

  /* ============================================
     MEGA MENU — Slide-in from Left
     ============================================ */
  .mega-menu {
    position: fixed;
    top: calc(var(--announcement-height) + var(--header-height));
    left: 0;
    bottom: 0;
    width: 56%;
    max-width: 720px;
    background-color: var(--color-bg);
    z-index: 200;
    transform: translateX(-100%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .mega-menu {
      width: 88%;
      max-width: none;
    }
  }

  .mega-menu.is-open {
    transform: translateX(0);
  }

  .mega-menu__inner {
    padding: 40px var(--page-padding) 60px;
    display: flex;
    gap: 60px;
    min-height: 100%;
    align-items: flex-start;
  }

  @media (max-width: 768px) {
    .mega-menu__inner {
      flex-direction: column;
      gap: 24px;
      padding: 32px 24px 40px;
    }
  }

  .mega-menu__left {
    flex-shrink: 0;
    min-width: 160px;
    padding-top: 0;
  }

  .mega-menu__heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0;
    line-height: 2.4;
    /* Stagger animation */
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease, transform 400ms ease;
    transition-delay: 150ms;
  }

  .mega-menu.is-open .mega-menu__heading {
    opacity: 1;
    transform: translateY(0);
  }

  .mega-menu__heading a {
    display: flex;
    align-items: center;
    gap: 10px;
    transition: opacity var(--duration-fast) ease;
  }

  .mega-menu__heading a:hover {
    opacity: 0.6;
  }

  .mega-menu__heading-arrow {
    font-size: 18px;
    transition: transform var(--duration-fast) ease;
  }

  .mega-menu__heading a:hover .mega-menu__heading-arrow {
    transform: translateX(4px);
  }

  .mega-menu__right {
    padding-top: 0;
  }

  .mega-menu__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Staggered fade-in for each link */
  .mega-menu__link {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    color: var(--color-text);
    line-height: 2.4;
    transition: opacity var(--duration-fast) ease;
    /* Stagger animation — start hidden */
    opacity: 0;
    transform: translateY(10px);
  }

  .mega-menu__link:hover {
    opacity: 0.6;
  }

  /* When menu is open, links animate in with staggered delays */
  .mega-menu.is-open .mega-menu__link {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease, transform 400ms ease;
  }

  .mega-menu.is-open .mega-menu__link:nth-child(1) { transition-delay: 200ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(2) { transition-delay: 260ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(3) { transition-delay: 320ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(4) { transition-delay: 380ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(5) { transition-delay: 440ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(6) { transition-delay: 500ms; }
  .mega-menu.is-open .mega-menu__link:nth-child(7) { transition-delay: 560ms; }

  /* Close button */
  .mega-menu__close {
    position: absolute;
    top: 40px;
    right: var(--page-padding);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: none;
    border: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 300ms ease;
    transition-delay: 300ms;
  }

  .mega-menu.is-open .mega-menu__close {
    opacity: 1;
  }

  .mega-menu__close svg {
    width: 18px;
    height: 18px;
  }

  .mega-menu__close:hover {
    opacity: 0.6;
  }

  /* Overlay behind mega menu — invisible, click-only */
  .mega-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: transparent;
    z-index: 199;
    pointer-events: none;
  }

  .mega-menu-overlay.is-open {
    pointer-events: auto;
  }
</style>

<header class="header" role="banner">
  <div class="header__inner">
    <!-- Mobile left: hamburger -->
    <div class="header__mobile-left">
      <button class="header__hamburger" data-menu-open aria-label="Open menu">
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Logo (left on desktop, center on mobile) -->
    <div class="header__logo">
      <a href="/" aria-label="{{ shop.name }}">
        <img src="{{ 'logo-v2.png' | asset_url }}" alt="{{ shop.name }}" class="header__logo-img">
      </a>
    </div>

    <!-- Center: Nav (desktop only) -->
    <nav class="header__nav desktop-only" role="navigation" aria-label="Main navigation">
      <div class="header__nav-item">
        <button class="header__nav-link" data-mega-trigger="all-jewelry">All Jewelry</button>
      </div>
      <div class="header__nav-item">
        <button class="header__nav-link" data-mega-trigger="new-in">New In</button>
      </div>
      <div class="header__nav-item">
        <button class="header__nav-link" data-mega-trigger="collections">Collections</button>
      </div>
      <div class="header__nav-item">
        <a href="/pages/materials" class="header__nav-link">Materials</a>
      </div>
    </nav>

    <!-- Right: Icons -->
    <div class="header__icons">
      <!-- Search -->
      <button class="header__icon-btn header__search-btn desktop-only" data-search-open aria-label="Search">
        <span class="header__search-input-wrap">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="9" r="6"></circle>
            <line x1="13.5" y1="13.5" x2="18" y2="18"></line>
          </svg>
        </span>
        <span class="header__search-label">Search</span>
      </button>

      <!-- Account (desktop) -->
      <a href="/account" class="header__icon-btn desktop-only" aria-label="Account">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="7" r="4"></circle>
          <path d="M3 19c0-4 3.5-7 7-7s7 3 7 7"></path>
        </svg>
      </a>

      <!-- Cart -->
      <button class="header__icon-btn header__cart-btn" data-cart-open aria-label="Open cart">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 7h10l-1 9H6L5 7z"></path>
          <path d="M8 7V5a2 2 0 0 1 4 0v2"></path>
        </svg>
        <span class="header__cart-count">{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

</header>

<!-- Mega menus — outside header to avoid stacking context trap (header z-index:100 would block overlay z-index:199) -->
