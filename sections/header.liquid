    </div>

    <!-- Mobile dropdown menu — inside header, opens below it -->
    <div class="mobile-dropdown" id="mobile-dropdown">
      <nav class="mobile-dropdown__nav" role="navigation">
        <div class="mobile-dropdown__item" data-mobile-accordion>
          <button class="mobile-dropdown__trigger">
            All Jewelry
