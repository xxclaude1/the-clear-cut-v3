          <a href="/pages/materials" class="header__nav-link">Materials</a>
        </div>
      </nav>

      <!-- Right: Icons -->
      <div class="header__icons">
        <!-- Search -->
        <button class="header__icon-btn header__search-btn desktop-only" data-search-open aria-label="Search">
          <span class="header__search-input-wrap">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="9" r="6"></circle>
              <line x1="13.5" y1="13.5" x2="18" y2="18"></line>
            </svg>
          </span>
          <span class="header__search-label">Search</span>
