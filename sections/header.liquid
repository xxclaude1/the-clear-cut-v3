            <path d="M8 7V5a2 2 0 0 1 4 0v2"></path>
          </svg>
          <span class="header__cart-count">{{ cart.item_count }}</span>
        </button>
      </div>
    </div>

    <!-- Desktop dropdown menus — inside header so they position relative to it -->
    <div class="dropdown-menu" id="dropdown-all-jewelry">
      <div class="dropdown-menu__inner">
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__heading">
            <a href="/collections/all-jewelry">All Jewelry <span class="dropdown-menu__heading-arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__links">
            <a href="/collections/all-jewelry" class="dropdown-menu__link">Shop All</a>
            <a href="/collections/earrings" class="dropdown-menu__link">Earrings</a>
            <a href="/collections/rings" class="dropdown-menu__link">Rings</a>
            <a href="/collections/bracelets" class="dropdown-menu__link">Bracelets</a>
            <a href="/collections/necklaces" class="dropdown-menu__link">Necklaces</a>
            <a href="/collections/tennis-jewelry" class="dropdown-menu__link">Tennis Jewelry</a>
          </div>
        </div>
      </div>
    </div>

    <div class="dropdown-menu" id="dropdown-new-in">
      <div class="dropdown-menu__inner">
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__heading">
            <a href="/collections/new-in">New In <span class="dropdown-menu__heading-arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__links">
            <a href="/collections/new-in" class="dropdown-menu__link">All New Arrivals</a>
            <a href="/collections/earrings" class="dropdown-menu__link">Earrings</a>
            <a href="/collections/rings" class="dropdown-menu__link">Rings</a>
            <a href="/collections/bracelets" class="dropdown-menu__link">Bracelets</a>
            <a href="/collections/necklaces" class="dropdown-menu__link">Necklaces</a>
