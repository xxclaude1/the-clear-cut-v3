        </div>
      </nav>

      <div class="mobile-dropdown__bottom">
        <a href="/search" class="mobile-dropdown__bottom-link">Search</a>
        <a href="/account" class="mobile-dropdown__bottom-link">Account</a>
      </div>
    </div>

    <!-- Overlay -->
    <div class="dropdown-overlay" id="dropdown-overlay"></div>
  </header>
</div>

<script>
  (function() {
    /* ---- Desktop Dropdown Menus ---- */
    var triggers = document.querySelectorAll('[data-dropdown-trigger]');
    var dropdowns = document.querySelectorAll('.dropdown-menu');
    var overlay = document.getElementById('dropdown-overlay');
    var currentOpen = null;

    function closeAllDropdowns() {
      dropdowns.forEach(function(d) { d.classList.remove('is-open'); });
      if (overlay) overlay.classList.remove('is-open');
      triggers.forEach(function(t) { t.classList.remove('is-active'); });
      currentOpen = null;
    }

    triggers.forEach(function(trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var id = 'dropdown-' + this.getAttribute('data-dropdown-trigger');
        var menu = document.getElementById(id);
        if (!menu) return;

        if (currentOpen === id) {
          closeAllDropdowns();
          return;
        }

        closeAllDropdowns();
        menu.classList.add('is-open');
        if (overlay) overlay.classList.add('is-open');
        trigger.classList.add('is-active');
        currentOpen = id;
      });
    });

    /* Close on link click inside dropdown */
    dropdowns.forEach(function(d) {
      d.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          closeAllDropdowns();
        });
      });
    });

    if (overlay) overlay.addEventListener('click', closeAllDropdowns);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && currentOpen) closeAllDropdowns();
    });

    /* ---- Mobile Dropdown Menu ---- */
    var mobileToggle = document.getElementById('mobile-menu-toggle');
    var mobileDropdown = document.getElementById('mobile-dropdown');
    var mobileOpen = false;

    if (mobileToggle && mobileDropdown) {
      mobileToggle.addEventListener('click', function() {
        mobileOpen = !mobileOpen;
        if (mobileOpen) {
          mobileDropdown.classList.add('is-open');
          mobileToggle.classList.add('is-active');
          document.body.style.overflow = 'hidden';
        } else {
          mobileDropdown.classList.remove('is-open');
          mobileToggle.classList.remove('is-active');
          document.body.style.overflow = '';
          /* Close all accordion sections */
          mobileDropdown.querySelectorAll('.mobile-dropdown__item.is-open').forEach(function(item) {
            item.classList.remove('is-open');
          });
        }
      });

      /* Mobile accordion */
      mobileDropdown.querySelectorAll('[data-mobile-accordion] .mobile-dropdown__trigger').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var item = this.closest('.mobile-dropdown__item');
          var wasOpen = item.classList.contains('is-open');
          /* Close siblings */
          item.parentElement.querySelectorAll('.mobile-dropdown__item.is-open').forEach(function(openItem) {
            if (openItem !== item) openItem.classList.remove('is-open');
          });
          if (wasOpen) {
            item.classList.remove('is-open');
          } else {
            item.classList.add('is-open');
          }
        });
      });

      /* Close mobile menu on link click */
      mobileDropdown.querySelectorAll('.mobile-dropdown__sub-link, .mobile-dropdown__link, .mobile-dropdown__bottom-link').forEach(function(link) {
        link.addEventListener('click', function() {
          mobileDropdown.classList.remove('is-open');
          mobileToggle.classList.remove('is-active');
          document.body.style.overflow = '';
        });
      });
    }
  })();
</script>

