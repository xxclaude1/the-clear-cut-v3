</div>

<div class="mega-menu" id="mega-collections">
  <button class="mega-menu__close" data-mega-close aria-label="Close menu">
    <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="2" y1="2" x2="16" y2="16"></line><line x1="16" y1="2" x2="2" y2="16"></line></svg>
