<style>
  #shopify-section-header {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header {
    background-color: var(--color-bg);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    position: relative;
    z-index: 2;
  }

  /* ---- Desktop header ---- */
  .header__inner {
    display: flex;
    align-items: center;
    height: var(--header-height);
    padding: 0 var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
    gap: 32px;
  }

  /* Left — Logo */
  .header__logo {
    flex-shrink: 0;
  }

  .header__logo a {
    display: block;
  }

  .header__logo-img {
    width: auto;
    height: auto;
    display: block;
    max-height: 40px;
  }

  @media (max-width: 768px) {
    .header__logo-img {
      max-height: 30px;
    }
  }

  /* Center — Nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    position: relative;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text);
    transition: opacity var(--duration-fast) ease;
    line-height: 1;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    white-space: nowrap;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    opacity: 0.6;
  }

  .header__nav-link.is-active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Right — Icons */
  .header__icons {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .header__icon-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    transition: opacity var(--duration-fast) ease;
    padding: 0;
  }

  .header__icon-btn:hover {
    opacity: 0.6;
  }

  .header__icon-btn svg {
    width: 20px;
    height: 20px;
  }

  .header__search-btn {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header__search-input-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
  }

  .header__search-input-wrap svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .header__search-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Cart count badge */
  .header__cart-btn {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-text);
    color: var(--color-btn-primary-text);
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    border-radius: 50%;
    padding: 0 4px;
    line-height: 1;
  }

  .header__cart-count:empty {
    display: none;
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 7px;
    width: 22px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__hamburger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: #1A1A1A;
    border-radius: 0;
    transition: transform 300ms ease, opacity 300ms ease;
  }

  /* Hamburger to X animation */
  .header__hamburger.is-active span:first-child {
    transform: translateY(4.25px) rotate(45deg);
  }
  .header__hamburger.is-active span:last-child {
    transform: translateY(-4.25px) rotate(-45deg);
  }

  /* ============================================
     MOBILE HEADER — hamburger LEFT, logo CENTER, icons RIGHT
     ============================================ */
  @media (max-width: 768px) {
    .header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-areas: "left center right";
      align-items: center;
      gap: 0;
    }

    .header__mobile-left {
      grid-area: left;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .header__logo {
      grid-area: center;
      display: flex;
      justify-content: center;
    }

    .header__icons {
      grid-area: right;
      justify-content: flex-end;
      gap: 16px;
    }

    /* Hide desktop nav on mobile */
    .header__nav {
      display: none;
    }
  }

  @media (min-width: 769px) {
    .header__mobile-left {
      display: none;
    }
  }

  /* ============================================
     DROPDOWN MEGA MENU — Opens below header
     ============================================ */

  /* Small arrow caret on the active nav link */
  .header__nav-link.is-active::after {
    content: '';
    position: absolute;
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-bottom: 6px solid var(--color-bg);
    z-index: 3;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    z-index: 1;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 400ms cubic-bezier(0.16, 1, 0.3, 1),
                opacity 300ms ease;
  }

  .dropdown-menu.is-open {
    max-height: 500px;
    opacity: 1;
  }

  .dropdown-menu__inner {
    display: flex;
    justify-content: center;
    gap: 80px;
    padding: 48px var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
  }

  .dropdown-menu__column {
    min-width: 140px;
  }

  .dropdown-menu__heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
    color: var(--color-text);
    /* Stagger animation */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 350ms ease, transform 350ms ease;
    transition-delay: 80ms;
  }

  .dropdown-menu.is-open .dropdown-menu__heading {
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-menu__heading a {
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity var(--duration-fast) ease;
  }

  .dropdown-menu__heading a:hover {
    opacity: 0.6;
  }

  .dropdown-menu__heading-arrow {
    font-size: 16px;
    transition: transform var(--duration-fast) ease;
  }

  .dropdown-menu__heading a:hover .dropdown-menu__heading-arrow {
    transform: translateX(4px);
  }

  .dropdown-menu__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dropdown-menu__link {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 2.4;
    transition: color var(--duration-fast) ease;
    /* Stagger animation */
    opacity: 0;
    transform: translateY(8px);
  }

  .dropdown-menu__link:hover {
    color: var(--color-text);
  }

  /* Staggered fade-in for links */
  .dropdown-menu.is-open .dropdown-menu__link {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 350ms ease, transform 350ms ease, color var(--duration-fast) ease;
  }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(1) { transition-delay: 120ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(2) { transition-delay: 170ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(3) { transition-delay: 220ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(4) { transition-delay: 270ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(5) { transition-delay: 320ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(6) { transition-delay: 370ms; }
  .dropdown-menu.is-open .dropdown-menu__link:nth-child(7) { transition-delay: 420ms; }

  /* Overlay behind dropdown — transparent, click-to-close only */
  .dropdown-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: transparent;
    z-index: -1;
    pointer-events: none;
  }

  .dropdown-overlay.is-open {
    pointer-events: auto;
  }

  /* ============================================
     MOBILE DROPDOWN MENU — slides down from header
     ============================================ */
  .mobile-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    z-index: 1;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 400ms cubic-bezier(0.16, 1, 0.3, 1),
                opacity 250ms ease;
  }

  .mobile-dropdown.is-open {
    max-height: calc(100vh - var(--header-height));
    opacity: 1;
    overflow-y: auto;
  }

  @media (min-width: 769px) {
    .mobile-dropdown {
      display: none;
    }
  }

  .mobile-dropdown__nav {
    padding: 8px 0;
  }

  .mobile-dropdown__item {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-dropdown__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px var(--page-padding);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    text-align: left;
  }

  .mobile-dropdown__trigger svg {
    width: 14px;
    height: 14px;
    transition: transform 300ms ease;
    flex-shrink: 0;
  }

  .mobile-dropdown__item.is-open .mobile-dropdown__trigger svg {
    transform: rotate(180deg);
  }

  .mobile-dropdown__link {
    display: block;
    padding: 16px var(--page-padding);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    text-decoration: none;
  }

  .mobile-dropdown__sub {
    max-height: 0;
    overflow: hidden;
    transition: max-height 350ms cubic-bezier(0.16, 1, 0.3, 1);
    background-color: var(--color-bg);
  }

  .mobile-dropdown__item.is-open .mobile-dropdown__sub {
    max-height: 400px;
  }

  .mobile-dropdown__sub-link {
    display: block;
    padding: 12px var(--page-padding) 12px 40px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity var(--duration-fast) ease;
  }

  .mobile-dropdown__sub-link:last-child {
    padding-bottom: 16px;
  }

  .mobile-dropdown__sub-link:active {
    opacity: 0.5;
  }

  .mobile-dropdown__bottom {
    padding: 16px var(--page-padding);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: 24px;
  }

  .mobile-dropdown__bottom-link {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-text-secondary);
    text-decoration: none;
  }
</style>

<div class="header-wrapper">
  <header class="header" role="banner">
    <div class="header__inner">
      <!-- Mobile left: hamburger -->
      <div class="header__mobile-left">
        <button class="header__hamburger" id="mobile-menu-toggle" aria-label="Open menu">
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Logo (left on desktop, center on mobile) -->
      <div class="header__logo">
        <a href="/" aria-label="{{ shop.name }}"{% unless section.settings.logo %} class="brand-wordmark"{% endunless %}>
          {%- if section.settings.logo -%}
            {%- assign logo_width_2x = section.settings.logo_width | times: 2 -%}
            <img src="{{ section.settings.logo | image_url: width: logo_width_2x }}" alt="{{ shop.name }}" class="header__logo-img" width="{{ logo_width_2x }}" height="{{ logo_width_2x | divided_by: 3 }}" style="max-width: {{ section.settings.logo_width }}px;">
          {%- else -%}
            THE CLEAR CUT
          {%- endif -%}
        </a>
      </div>

      <!-- Center: Nav (desktop only) -->
      <nav class="header__nav desktop-only" role="navigation" aria-label="Main navigation">
        <div class="header__nav-item">
          <button class="header__nav-link" data-dropdown-trigger="all-jewelry">All Jewelry</button>
        </div>
        <div class="header__nav-item">
          <button class="header__nav-link" data-dropdown-trigger="new-in">New In</button>
