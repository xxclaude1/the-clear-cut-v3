      </div>
    </div>

    <div class="dropdown-menu" id="dropdown-collections">
      <div class="dropdown-menu__inner">
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__heading">
            <a href="/collections">Collections <span class="dropdown-menu__heading-arrow">&rarr;</span></a>
          </div>
        </div>
        <div class="dropdown-menu__column">
          <div class="dropdown-menu__links">
            <a href="/collections/the-essentials" class="dropdown-menu__link">The Essentials</a>
            <a href="/collections/the-statement-edit" class="dropdown-menu__link">The Statement Edit</a>
            <a href="/collections/the-gift-guide" class="dropdown-menu__link">The Gift Guide</a>
