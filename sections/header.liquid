      </div>
    </div>
  </div>
</div>

<!-- Mega menu overlay -->
<div class="mega-menu-overlay" id="mega-overlay"></div>

<script>
  (function() {
    var triggers = document.querySelectorAll('[data-mega-trigger]');
    var menus = document.querySelectorAll('.mega-menu');
    var overlay = document.getElementById('mega-overlay');
    var closeBtns = document.querySelectorAll('[data-mega-close]');
    var currentOpen = null;

    function closeAll() {
      menus.forEach(function(m) { m.classList.remove('is-open'); });
      overlay.classList.remove('is-open');
      triggers.forEach(function(t) { t.classList.remove('is-active'); });
      document.body.style.overflow = '';
      currentOpen = null;
    }

    triggers.forEach(function(trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var id = 'mega-' + this.getAttribute('data-mega-trigger');
        var menu = document.getElementById(id);
        if (!menu) return;

        if (currentOpen === id) {
          closeAll();
          return;
        }

        closeAll();
        /* Small RAF delay so close transitions finish before open starts */
        requestAnimationFrame(function() {
          menu.classList.add('is-open');
          overlay.classList.add('is-open');
          trigger.classList.add('is-active');
          document.body.style.overflow = 'hidden';
          currentOpen = id;
        });
      });
    });

    closeBtns.forEach(function(btn) {
      btn.addEventListener('click', closeAll);
    });

    overlay.addEventListener('click', closeAll);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && currentOpen) closeAll();
    });
  })();
</script>

