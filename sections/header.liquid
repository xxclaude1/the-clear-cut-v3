            <a href="/collections/all-jewelry" class="mobile-dropdown__sub-link">Shop All</a>
            <a href="/collections/earrings" class="mobile-dropdown__sub-link">Earrings</a>
            <a href="/collections/rings" class="mobile-dropdown__sub-link">Rings</a>
            <a href="/collections/bracelets" class="mobile-dropdown__sub-link">Bracelets</a>
            <a href="/collections/necklaces" class="mobile-dropdown__sub-link">Necklaces</a>
            <a href="/collections/tennis-jewelry" class="mobile-dropdown__sub-link">Tennis Jewelry</a>
          </div>
        </div>

        <div class="mobile-dropdown__item" data-mobile-accordion>
          <button class="mobile-dropdown__trigger">
            New In
            <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="3,5 7,9 11,5"></polyline></svg>
          </button>
          <div class="mobile-dropdown__sub">
            <a href="/collections/new-in" class="mobile-dropdown__sub-link">All New Arrivals</a>
            <a href="/collections/earrings" class="mobile-dropdown__sub-link">Earrings</a>
            <a href="/collections/rings" class="mobile-dropdown__sub-link">Rings</a>
            <a href="/collections/bracelets" class="mobile-dropdown__sub-link">Bracelets</a>
