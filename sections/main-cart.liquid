<style>
  .cart-page {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--page-padding);
  }

  .cart-page__title {
    margin-bottom: var(--space-lg);
  }

  .cart-page__header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr auto;
    gap: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-md);
  }

  .cart-page__header span {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
  }

  .cart-page__header span:nth-child(3) {
    text-align: right;
  }

  .cart-page__item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .cart-page__header {
      display: none;
    }
    .cart-page__item {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .cart-page__item-info {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .cart-page__item-image {
    width: 100px;
    height: 100px;
    background-color: var(--color-bg-warm);
    flex-shrink: 0;
  }

  .cart-page__item-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cart-page__item-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
  }

  .cart-page__item-variant {
    font-size: 12px;
    color: var(--color-text-secondary);
    margin-top: 4px;
  }

  .cart-page__item-unit-price {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-top: 4px;
  }

  .cart-page__item-price {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    text-align: right;
  }

  /* Quantity controls */
  .cart-page__qty {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    width: fit-content;
  }

  .cart-page__qty-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    cursor: pointer;
    transition: background-color var(--duration-fast) ease;
  }

  .cart-page__qty-btn:hover {
    background-color: var(--color-bg-warm);
  }

  .cart-page__qty-value {
    width: 40px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    line-height: 36px;
  }

  /* Remove button */
  .cart-page__remove {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
    transition: opacity var(--duration-fast) ease;
    padding: 4px;
  }

  .cart-page__remove:hover {
    opacity: 0.6;
  }

  .cart-page__footer {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
    margin-top: var(--space-lg);
  }

  @media (max-width: 768px) {
    .cart-page__footer {
      align-items: stretch;
    }
  }

  .cart-page__subtotal {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .cart-page__subtotal-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 18px;
  }

  .cart-page__subtotal-price {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 18px;
  }

  .cart-page__checkout-btn {
    width: 320px;
  }

  @media (max-width: 768px) {
    .cart-page__checkout-btn {
      width: 100%;
    }
  }

  .cart-page__shipping-note {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .cart-page__empty {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .cart-page__empty p {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .cart-page__continue {
    display: inline-block;
    margin-top: var(--space-sm);
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>

<div class="cart-page">
  <h1 class="heading-1 cart-page__title">Your Cart ({{ cart.item_count }})</h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-page__empty">
      <p>Your cart is empty.</p>
      <a href="/collections/all" class="btn-outline">Continue Shopping</a>
    </div>
  {%- else -%}
    <div class="cart-page__header desktop-only">
      <span>Product</span>
      <span>Quantity</span>
      <span>Total</span>
      <span></span>
    </div>

    {%- for item in cart.items -%}
      <div class="cart-page__item" data-line="{{ forloop.index }}">
        <div class="cart-page__item-info">
          <div class="cart-page__item-image">
            {%- if item.image -%}
              <a href="{{ item.url }}">
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
              </a>
            {%- endif -%}
          </div>
          <div>
            <a href="{{ item.url }}" class="cart-page__item-name">{{ item.product.title }}</a>
            {%- unless item.variant.title == 'Default Title' -%}
              <div class="cart-page__item-variant">{{ item.variant.title }}</div>
            {%- endunless -%}
            <div class="cart-page__item-unit-price">{{ item.price | money }} each</div>
          </div>
        </div>

        <div class="cart-page__qty">
          <button class="cart-page__qty-btn" data-cart-change data-line="{{ forloop.index }}" data-quantity="{{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">−</button>
          <span class="cart-page__qty-value">{{ item.quantity }}</span>
          <button class="cart-page__qty-btn" data-cart-change data-line="{{ forloop.index }}" data-quantity="{{ item.quantity | plus: 1 }}" aria-label="Increase quantity">+</button>
        </div>

        <div class="cart-page__item-price">{{ item.final_line_price | money }}</div>

        <button class="cart-page__remove" data-cart-change data-line="{{ forloop.index }}" data-quantity="0" aria-label="Remove {{ item.product.title }}">
          Remove
        </button>
      </div>
    {%- endfor -%}

    <div class="cart-page__footer">
      <div class="cart-page__subtotal">
        <span class="cart-page__subtotal-label">Subtotal</span>
        <span class="cart-page__subtotal-price">{{ cart.total_price | money }}</span>
      </div>
      <span class="cart-page__shipping-note">Shipping calculated at checkout.</span>
      <a href="/checkout" class="btn-primary cart-page__checkout-btn">Check Out</a>
      <a href="/collections/all" class="cart-page__continue">Continue shopping</a>
    </div>
  {%- endif -%}
</div>

<script>
  document.querySelectorAll('[data-cart-change]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var line = this.getAttribute('data-line');
      var quantity = parseInt(this.getAttribute('data-quantity'), 10);
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: parseInt(line, 10), quantity: quantity })
      }).then(function() {
        window.location.reload();
      });
    });
  });
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
