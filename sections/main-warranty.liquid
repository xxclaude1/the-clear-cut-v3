    padding: var(--space-2xl) var(--page-padding);
  }

  .warranty-page__title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .warranty-page h2 {
    font-size: 20px;
    margin-top: 40px;
    margin-bottom: 16px;
  }

  .warranty-page p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .warranty-page ul {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .warranty-page li {
    list-style: disc;
