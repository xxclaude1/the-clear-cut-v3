<style>
  .sustainability {
    background-color: #E0DBD5;
    padding: 56px var(--page-padding);
  }

  .sustainability__inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (max-width: 768px) {
    .sustainability {
      padding: 40px var(--page-padding);
    }

    .sustainability__inner {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  .sustainability__heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #4A443E;
    margin-bottom: 14px;
  }

  .sustainability__cta {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #4A443E;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .sustainability__body {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.75;
    color: #5C554F;
  }
</style>

<section class="sustainability reveal">
  <div class="sustainability__inner">
    <div>
      <h2 class="sustainability__heading">{{ section.settings.heading | default: 'Our Sustainability Progress' }}</h2>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url }}" class="sustainability__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
    <div>
      <p class="sustainability__body">{{ section.settings.body | default: "Our journey mirrors that of the jewelry we create — crafted through collaboration and constant evolution. We're here to transform fine jewelry into everyday moments, empower our community, and drive meaningful change in our communities and beyond." }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sustainability",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Sustainability Progress" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Our journey mirrors that of the jewelry we create — crafted through collaboration and constant evolution. We're here to transform fine jewelry into everyday moments, empower our community, and drive meaningful change in our communities and beyond." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "View Sustainability Report" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Sustainability" }]
}
{% endschema %}
