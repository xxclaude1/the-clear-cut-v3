  "name": "Hero",
  "settings": [
    { "type": "header", "content": "Top Left" },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "text", "id": "heading_1", "label": "Heading" },
    { "type": "text", "id": "body_1", "label": "Body text" },
    { "type": "text", "id": "cta_text_1", "label": "CTA text" },
    { "type": "url", "id": "cta_url_1", "label": "CTA link" },
    { "type": "color", "id": "text_color_1", "label": "Text color", "default": "#FFFFFF" },

    { "type": "header", "content": "Top Right" },
    { "type": "image_picker", "id": "image_2", "label": "Image" },
    { "type": "text", "id": "heading_2", "label": "Heading" },
    { "type": "text", "id": "body_2", "label": "Body text" },
    { "type": "text", "id": "cta_text_2", "label": "CTA text" },
    { "type": "url", "id": "cta_url_2", "label": "CTA link" },
    { "type": "color", "id": "text_color_2", "label": "Text color", "default": "#FFFFFF" },

    { "type": "header", "content": "Bottom Left" },
    { "type": "image_picker", "id": "image_3", "label": "Image" },
    { "type": "text", "id": "heading_3", "label": "Heading", "default": "Start Your Collection" },
    { "type": "text", "id": "body_3", "label": "Body text", "default": "Our Tennis Bracelets are waiting." },
    { "type": "text", "id": "cta_text_3", "label": "CTA text", "default": "Shop The Collection" },
    { "type": "url", "id": "cta_url_3", "label": "CTA link" },
    { "type": "color", "id": "text_color_3", "label": "Text color", "default": "#FFFFFF" },

    { "type": "header", "content": "Bottom Right" },
    { "type": "image_picker", "id": "image_4", "label": "Image" },
    { "type": "text", "id": "heading_4", "label": "Heading" },
    { "type": "text", "id": "body_4", "label": "Body text" },
    { "type": "text", "id": "cta_text_4", "label": "CTA text" },
    { "type": "url", "id": "cta_url_4", "label": "CTA link" },
    { "type": "color", "id": "text_color_4", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
