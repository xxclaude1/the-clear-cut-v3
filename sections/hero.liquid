<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--card-gap);
    min-height: 75vh;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }

  .hero__column {
    position: relative;
    overflow: hidden;
    min-height: 50vh;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .hero:hover .hero__column:first-child .hero__image {
    transform: scale(1.02);
  }

  .hero__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-warm);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__placeholder-text {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 48px;
    max-width: 500px;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero__overlay {
      padding: 24px;
    }
  }

  .hero__heading {
    margin-bottom: 12px;
    color: {{ section.settings.text_color }};
  }

  .hero__body {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
  }

  .hero__cta {
    color: {{ section.settings.text_color }};
  }
</style>

<section class="hero">
  <div class="hero__column">
    {%- if section.settings.image_left != blank -%}
      <img class="hero__image" src="{{ section.settings.image_left | image_url: width: 1400 }}" alt="{{ section.settings.heading | escape }}" loading="eager" fetchpriority="high">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
    <div class="hero__overlay">
      <h1 class="heading-display hero__heading">{{ section.settings.heading | default: 'Start Your Collection' }}</h1>
      <p class="hero__body">{{ section.settings.body | default: 'Our Tennis Bracelets are waiting.' }}</p>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="editorial-cta hero__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="hero__column">
    {%- if section.settings.image_right != blank -%}
      <img class="hero__image" src="{{ section.settings.image_right | image_url: width: 1400 }}" alt="{{ section.settings.image_right_alt | default: '' }}" loading="eager">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Collection"
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body text",
      "default": "Our Tennis Bracelets are waiting."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Shop Tennis Bracelets"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "image_right_alt",
      "label": "Right image alt text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
