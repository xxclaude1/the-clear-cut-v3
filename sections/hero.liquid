<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    min-height: 75vh;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
  }

  .hero__column {
    position: relative;
    overflow: hidden;
    min-height: 50vh;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 40px;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .hero__overlay {
      padding: 24px;
    }
  }

  .hero__heading {
    margin-bottom: 12px;
  }

  .hero__body {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 16px;
  }
</style>

<section class="hero reveal">
  <div class="hero__column">
    {%- if section.settings.image_left != blank -%}
      <img class="hero__image" src="{{ section.settings.image_left | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="eager">
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--color-bg-warm);"></div>
    {%- endif -%}
    <div class="hero__overlay">
      <h1 class="heading-display hero__heading">{{ section.settings.heading | default: 'Start Your Collection' }}</h1>
      <p class="hero__body">{{ section.settings.body | default: 'Our Tennis Bracelets are waiting.' }}</p>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="editorial-cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="hero__column">
    {%- if section.settings.image_right != blank -%}
      <img class="hero__image" src="{{ section.settings.image_right | image_url: width: 1200 }}" alt="" loading="eager">
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--color-bg-warm);"></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Collection"
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body text",
      "default": "Our Tennis Bracelets are waiting."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Shop Tennis Bracelets"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
