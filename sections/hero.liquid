<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--card-gap);
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      gap: 2px;
    }
  }

  .hero__column {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  @media (max-width: 768px) {
    .hero__column {
      aspect-ratio: 4 / 5;
    }
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .hero__column:hover .hero__image {
    transform: scale(1.02);
  }

  .hero__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-warm);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__placeholder-text {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 40px;
    max-width: 480px;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero__overlay {
      padding: 12px;
      max-width: 100%;
    }

    .hero__overlay .heading-display {
      font-size: 14px;
    }

    .hero__overlay .hero__body {
      font-size: 10px;
      margin-bottom: 8px;
      line-height: 1.4;
    }

    .hero__overlay .editorial-cta {
      font-size: 9px;
    }
  }

  .hero__heading {
    margin-bottom: 10px;
  }

  .hero__body {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 16px;
    opacity: 0.9;
  }
</style>

<section class="hero">
  <!-- Top left -->
  <div class="hero__column">
    {%- if section.settings.image_1 != blank -%}
      <img class="hero__image" src="{{ section.settings.image_1 | image_url: width: 1400 }}" alt="{{ section.settings.heading_1 | escape }}" loading="eager" fetchpriority="high">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
    {%- if section.settings.heading_1 != blank -%}
      <div class="hero__overlay">
        <h2 class="heading-display hero__heading" style="color:{{ section.settings.text_color_1 }}">{{ section.settings.heading_1 }}</h2>
        {%- if section.settings.body_1 != blank -%}
          <p class="hero__body" style="color:{{ section.settings.text_color_1 }}">{{ section.settings.body_1 }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text_1 != blank -%}
          <a href="{{ section.settings.cta_url_1 | default: '/collections/all' }}" class="editorial-cta" style="color:{{ section.settings.text_color_1 }}">{{ section.settings.cta_text_1 }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Top right -->
  <div class="hero__column">
    {%- if section.settings.image_2 != blank -%}
      <img class="hero__image" src="{{ section.settings.image_2 | image_url: width: 1400 }}" alt="{{ section.settings.heading_2 | default: '' | escape }}" loading="eager">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
    {%- if section.settings.heading_2 != blank -%}
      <div class="hero__overlay">
        <h2 class="heading-display hero__heading" style="color:{{ section.settings.text_color_2 }}">{{ section.settings.heading_2 }}</h2>
        {%- if section.settings.body_2 != blank -%}
          <p class="hero__body" style="color:{{ section.settings.text_color_2 }}">{{ section.settings.body_2 }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text_2 != blank -%}
          <a href="{{ section.settings.cta_url_2 }}" class="editorial-cta" style="color:{{ section.settings.text_color_2 }}">{{ section.settings.cta_text_2 }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Bottom left -->
  <div class="hero__column">
    {%- if section.settings.image_3 != blank -%}
      <img class="hero__image" src="{{ section.settings.image_3 | image_url: width: 1400 }}" alt="{{ section.settings.heading_3 | default: '' | escape }}" loading="lazy">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
    {%- if section.settings.heading_3 != blank -%}
      <div class="hero__overlay">
        <h2 class="heading-display hero__heading" style="color:{{ section.settings.text_color_3 }}">{{ section.settings.heading_3 }}</h2>
        {%- if section.settings.body_3 != blank -%}
          <p class="hero__body" style="color:{{ section.settings.text_color_3 }}">{{ section.settings.body_3 }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text_3 != blank -%}
          <a href="{{ section.settings.cta_url_3 }}" class="editorial-cta" style="color:{{ section.settings.text_color_3 }}">{{ section.settings.cta_text_3 }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Bottom right -->
  <div class="hero__column">
    {%- if section.settings.image_4 != blank -%}
      <img class="hero__image" src="{{ section.settings.image_4 | image_url: width: 1400 }}" alt="{{ section.settings.heading_4 | default: '' | escape }}" loading="lazy">
    {%- else -%}
      <div class="hero__placeholder">
        <span class="hero__placeholder-text">Hero image — 1400 x 900 recommended</span>
      </div>
    {%- endif -%}
    {%- if section.settings.heading_4 != blank -%}
      <div class="hero__overlay">
        <h2 class="heading-display hero__heading" style="color:{{ section.settings.text_color_4 }}">{{ section.settings.heading_4 }}</h2>
        {%- if section.settings.body_4 != blank -%}
          <p class="hero__body" style="color:{{ section.settings.text_color_4 }}">{{ section.settings.body_4 }}</p>
        {%- endif -%}
        {%- if section.settings.cta_text_4 != blank -%}
          <a href="{{ section.settings.cta_url_4 }}" class="editorial-cta" style="color:{{ section.settings.text_color_4 }}">{{ section.settings.cta_text_4 }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

