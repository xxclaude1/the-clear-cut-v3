    if (numMatch) {
      var silverNum = parseFloat(numMatch[1].replace(/,/g, ''));
      var goldNum = Math.round(silverNum * 1.3);
      goldPriceText = silverPriceOriginal.replace(numMatch[1], goldNum.toLocaleString('en-AU', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
    }
  }

