<script>
  /* Variant selection */
  document.querySelectorAll('.product-page__variant-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var group = this.closest('.product-page__variant-options');
      group.querySelectorAll('.product-page__variant-btn').forEach(function(b) {
        b.classList.remove('is-selected');
      });
      this.classList.add('is-selected');
    });
  });
</script>

