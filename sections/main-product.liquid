<style>
  /* Prevent horizontal page scroll on mobile */
  html, body {
    overflow-x: hidden;
  }

  .product-page {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  @media (max-width: 768px) {
    .product-page {
      grid-template-columns: 1fr;
    }
  }

  /* Gallery — full bleed images stacked */
  .product-page__gallery {
    position: relative;
  }

  .product-page__gallery-images {
    display: flex;
    flex-direction: column;
  }

  .product-page__gallery-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background-color: var(--color-bg-warm);
  }

  /* Info panel — sticky on desktop */
  .product-page__info {
    padding: 48px 48px 48px 56px;
  }

  @media (min-width: 769px) {
    .product-page__info {
      position: sticky;
      top: var(--header-height);
      align-self: start;
      max-height: calc(100vh - var(--header-height));
      overflow-y: auto;
      scrollbar-width: none;
    }

    .product-page__info::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .product-page__info {
      padding: var(--space-md) var(--page-padding);
    }
  }

  /* Title row */
  .product-page__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 8px;
  }

  .product-page__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1.25;
  }

  @media (max-width: 768px) {
    .product-page__title {
      font-size: 18px;
    }
  }

  /* Price */
  .product-page__price {
    margin-bottom: 24px;
  }

  .product-page__price-from {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-right: 4px;
  }

  .product-page__price-amount {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.3;
    color: var(--color-text);
  }

  .product-page__price-strike {
    font-weight: 400;
    text-decoration: line-through;
    color: var(--color-text-secondary);
    margin-right: 8px;
  }

  /* Material info */
  .product-page__material {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-secondary);
    margin-bottom: 28px;
    line-height: 1.5;
  }

  /* Size guide — standalone link */
  .product-page__size-guide-standalone {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    transition: opacity var(--duration-fast) ease;
  }

  .product-page__size-guide-standalone:hover {
    opacity: 0.6;
  }

  /* Color swatches */
  .product-page__swatches {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 28px;
  }

  .product-page__swatch {
    width: 20px;
    height: 20px;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
  }

  .product-page__swatch:hover,
  .product-page__swatch.is-selected {
    border-color: var(--color-text);
  }

  .product-page__swatch--silver { background-color: #C0C0C0; }
  .product-page__swatch--gold { background-color: #D4A853; }
  .product-page__swatch--rose { background-color: #B76E79; }

  .product-page__swatch.is-unavailable {
    opacity: 0.45;
    cursor: pointer;
    position: relative;
  }
  .product-page__swatch.is-unavailable.is-selected {
    border-color: var(--color-text);
    opacity: 0.6;
  }
  .product-page__swatch.is-unavailable::after {
    content: '';
    position: absolute;
    top: 50%;
    left: -2px;
    right: -2px;
    height: 1px;
    background: var(--color-text-secondary);
    transform: rotate(-45deg);
  }

  /* Variant selector — Length */
  .product-page__variant-group {
    margin-bottom: 24px;
  }

  .product-page__variant-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .product-page__variant-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text);
  }

  .product-page__size-guide {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity var(--duration-fast) ease;
  }

  .product-page__size-guide:hover {
    opacity: 0.6;
  }

  .product-page__variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .product-page__variant-btn {
    font-family: var(--font-body);
    font-size: 13px;
    padding: 10px 20px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
    line-height: 1;
  }

  .product-page__variant-btn:hover {
    border-color: var(--color-text);
  }

  .product-page__variant-btn.is-selected {
    border: 2px solid var(--color-text);
  }

  .product-page__variant-btn.is-unavailable {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Add to bag row */
  .product-page__add-row {
    display: flex;
    gap: 0;
    margin-bottom: 16px;
  }

  .product-page__add-btn {
    flex: 1;
    height: 56px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background-color: var(--color-btn-primary-bg);
    color: var(--color-btn-primary-text);
    border: none;
    cursor: pointer;
    transition: background-color var(--duration-fast) ease;
    line-height: 1;
  }

  .product-page__add-btn:hover {
    background-color: var(--color-btn-primary-hover);
  }

  .product-page__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .product-page__wishlist-btn {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-btn-primary-bg);
    border: none;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition: background-color var(--duration-fast) ease;
  }

  .product-page__wishlist-btn:hover {
    background-color: var(--color-btn-primary-hover);
  }

  .product-page__wishlist-btn svg {
    width: 20px;
    height: 20px;
    stroke: white;
    fill: none;
    stroke-width: 1.5;
  }

  /* Description */
  .product-page__description {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 32px;
  }

  /* Feature list */
  .product-page__features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .product-page__feature {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .product-page__feature-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-page__feature-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--color-text);
    fill: none;
    stroke-width: 1.2;
  }

  .product-page__feature-text {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text);
  }

  /* Accordions */
  .product-page__accordions {
    border-top: 1px solid var(--color-border);
  }

  .accordion__item {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 20px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .accordion__icon {
    font-size: 18px;
    font-weight: 300;
    line-height: 1;
    transition: transform var(--duration-fast) ease;
  }

  .accordion__item.is-open .accordion__icon {
    transform: none;
  }

  .accordion__content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms ease;
  }

  .accordion__content-inner {
    padding: 0 0 20px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .specs-table { width: 100%; }

  .specs-table__row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: 13px;
  }

  .specs-table__label { color: var(--color-text-secondary); }

  /* Reviews section */
  .product-page__reviews {
    grid-column: 1 / -1;
    padding: 80px var(--page-padding) 60px;
    max-width: var(--page-max-width);
    margin: 0 auto;
    width: 100%;
  }
  @media (max-width: 768px) {
    .product-page__reviews {
      padding: 40px var(--page-padding) 32px;
    }
  }

  .reviews__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .reviews__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .reviews__summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-bottom: 8px;
  }

  .reviews__average {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 48px;
    color: var(--color-text);
    line-height: 1;
  }

  .reviews__summary-right {
    text-align: left;
  }

  .reviews__summary-stars {
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .reviews__summary-count {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  /* Star breakdown bars */
  .reviews__breakdown {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 320px;
    margin: 24px auto 0;
  }

  .reviews__breakdown-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .reviews__breakdown-label {
    width: 36px;
    text-align: right;
    flex-shrink: 0;
  }

  .reviews__breakdown-bar {
    flex: 1;
    height: 6px;
    background: var(--color-border);
    position: relative;
  }

  .reviews__breakdown-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    background: var(--color-text);
    transition: width 600ms ease;
  }

  .reviews__breakdown-count {
    width: 28px;
    flex-shrink: 0;
    text-align: left;
  }

  /* Photo gallery strip */
  .reviews__photos {
    margin-bottom: 40px;
  }

  .reviews__photos-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .reviews__photos-scroll {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
  }

  .reviews__photos-scroll::-webkit-scrollbar {
    display: none;
  }

  .reviews__photo-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    flex-shrink: 0;
    cursor: pointer;
    border: 1px solid var(--color-border);
    transition: border-color var(--duration-fast) ease;
  }

  .reviews__photo-thumb:hover {
    border-color: var(--color-text);
  }

  /* Sort & controls bar */
  .reviews__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .reviews__sort {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .reviews__sort-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .reviews__sort-select {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 8px 32px 8px 12px;
    background: var(--color-bg);
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%231A1A1A' stroke-width='1.2' fill='none'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    cursor: pointer;
  }

  .reviews__write-btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 10px 24px;
    border: 1px solid var(--color-text);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
  }

  .reviews__write-btn:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  @media (max-width: 768px) {
    .reviews__controls {
      flex-direction: column;
      gap: 12px;
      align-items: stretch;
    }
    .reviews__sort {
      justify-content: space-between;
    }
    .reviews__write-btn {
      text-align: center;
    }
  }

  /* Review cards grid */
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 32px;
  }

  @media (max-width: 768px) {
    .reviews__grid {
      grid-template-columns: 1fr;
    }
  }

  .review-card {
    background: var(--color-bg);
    padding: 28px;
  }

  .review-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .review-card__stars {
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--color-text);
  }

  .review-card__date {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .review-card__text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .review-card__photo {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border: 1px solid var(--color-border);
    margin-bottom: 16px;
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
  }

  .review-card__photo:hover {
    border-color: var(--color-text);
  }

  .review-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .review-card__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .review-card__author {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  .review-card__location {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .review-card__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .review-card__verified {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .review-card__verified svg {
    width: 12px;
    height: 12px;
    stroke: var(--color-text);
    fill: none;
    stroke-width: 2;
  }

  .review-card__variant {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-secondary);
  }

  /* Show more button */
  .reviews__show-more {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .reviews__show-more-btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 14px 48px;
    border: 1px solid var(--color-text);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
  }

  .reviews__show-more-btn:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  /* Write a Review Modal */
  .review-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .review-modal.is-open {
    display: flex;
  }

  .review-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .review-modal__content {
    position: relative;
    background: var(--color-bg);
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 40px;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .review-modal__content {
      max-width: 100%;
      margin: 0 16px;
      padding: 28px 20px;
    }
  }

  .review-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
    padding: 4px;
  }

  .review-modal__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 28px;
  }

  .review-modal__field {
    margin-bottom: 20px;
  }

  .review-modal__label {
    display: block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .review-modal__input,
  .review-modal__textarea {
    width: 100%;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--duration-fast) ease;
  }

  .review-modal__input:focus,
  .review-modal__textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .review-modal__textarea {
    min-height: 120px;
    resize: vertical;
  }

  .review-modal__stars-input {
    display: flex;
    gap: 4px;
    margin-bottom: 4px;
  }

  .review-modal__star {
    font-size: 24px;
    cursor: pointer;
    color: var(--color-border);
    transition: color var(--duration-fast) ease;
    background: none;
    border: none;
    padding: 0;
    line-height: 1;
  }

  .review-modal__star.is-active {
    color: var(--color-text);
  }

  .review-modal__drop-zone {
    border: 2px dashed var(--color-border);
    padding: 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
  }

  .review-modal__drop-zone:hover,
  .review-modal__drop-zone.is-dragover {
    border-color: var(--color-text);
  }

  .review-modal__drop-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .review-modal__drop-text span {
    text-decoration: underline;
    color: var(--color-text);
  }

  .review-modal__file-input {
    display: none;
  }

  .review-modal__preview {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .review-modal__preview-img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .review-modal__submit {
    width: 100%;
    height: 48px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-btn-primary-bg);
    color: var(--color-btn-primary-text);
    border: none;
    cursor: pointer;
    transition: background-color var(--duration-fast) ease;
    margin-top: 8px;
  }

  .review-modal__submit:hover {
    background: var(--color-btn-primary-hover);
  }

  .review-modal__success {
    display: none;
    text-align: center;
    padding: 40px 0;
  }

  .review-modal__success.is-visible {
    display: block;
  }

  .review-modal__success-icon {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .review-modal__success-text {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text);
  }

  /* Lightbox */
  .review-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.85);
  }

  .review-lightbox.is-open {
    display: flex;
  }

  .review-lightbox__close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
  }

  .review-lightbox__img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
  }

  /* Size Guide Modal */
  .size-guide-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9998;
    align-items: center;
    justify-content: center;
  }
  .size-guide-modal.is-open { display: flex; }
  .size-guide-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
  }
  .size-guide-modal__content {
    position: relative;
    background: var(--color-bg);
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 32px;
    z-index: 1;
  }
  @media (max-width: 768px) {
    .size-guide-modal {
      align-items: flex-end;
    }
    .size-guide-modal__content {
      max-width: 100%;
      margin: 0;
      padding: 24px 20px 32px;
      border-radius: 16px 16px 0 0;
      max-height: 85vh;
      animation: slideUp 300ms ease;
    }
    @keyframes slideUp {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }
  }
  .size-guide-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
  }
  .size-guide-modal__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }
  .size-guide-modal__image img {
    width: 100%;
    display: block;
    margin-bottom: 24px;
    border-radius: 0;
  }
  .size-guide-modal__tabs {
    display: flex;
    gap: 24px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }
  .size-guide-modal__tab {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0 0 12px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: all var(--duration-fast) ease;
  }
  .size-guide-modal__tab.is-active {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
  }
  .size-guide-modal__panel { display: none; }
  .size-guide-modal__panel.is-active { display: block; }
  .size-guide-modal__table {
    width: 100%;
    border-collapse: collapse;
  }
  .size-guide-modal__table th,
  .size-guide-modal__table td {
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
    text-align: left;
  }
  .size-guide-modal__table th {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    color: var(--color-text);
  }
  .size-guide-modal__table td {
    color: var(--color-text-secondary);
  }
  .size-guide-modal__style-item {
    margin-bottom: 24px;
  }
  .size-guide-modal__style-size {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 6px;
  }
  .size-guide-modal__style-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* In Stock badge */
  .product-page__stock {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  /* You May Also Like — horizontal slider */
  .product-page__related {
    grid-column: 1 / -1;
    padding: 60px var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
    width: 100%;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .product-page__related {
      padding: 32px var(--page-padding);
    }
  }
  .related__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .related__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0;
  }
  .related__nav {
    display: flex;
    gap: 8px;
  }
  .related__nav-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
  }
  .related__nav-btn:hover {
    border-color: var(--color-text);
  }
  .related__nav-btn svg {
    width: 10px;
    height: 10px;
  }
  .related__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 2px;
    scroll-behavior: smooth;
  }
  .related__grid::-webkit-scrollbar { display: none; }
  .related__card {
    flex: 0 0 calc(25% - 1.5px);
    scroll-snap-align: start;
    background: var(--color-bg-warm);
    text-decoration: none;
    color: var(--color-text);
    display: block;
  }
  @media (max-width: 768px) {
    .related__card {
      flex: 0 0 70%;
    }
  }
  .related__card-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    display: block;
    background: var(--color-bg-warm);
  }
  .related__card-info {
    padding: 16px;
    background: var(--color-bg);
  }
  .related__card-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .related__card-price {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text);
    margin-bottom: 6px;
  }
  .related__card-material {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-secondary);
  }

  /* Quote banner */
  .product-page__quote {
    grid-column: 1 / -1;
    text-align: center;
    padding: 64px var(--page-padding);
  }
  @media (max-width: 768px) {
    .product-page__quote {
      padding: 32px var(--page-padding);
    }
  }
  .product-page__quote-text {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-text);
    max-width: 640px;
    margin: 0 auto 16px;
  }
  @media (max-width: 768px) {
    .product-page__quote-text { font-size: 22px; }
  }
  .product-page__quote-sub {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  /* Sustainability banner on product page */
  .product-page__sustainability {
    grid-column: 1 / -1;
    background-color: #E0DBD5;
    padding: 56px var(--page-padding);
  }
  .product-page__sustainability-inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .product-page__sustainability-inner { grid-template-columns: 1fr; gap: 20px; }
  }
  .product-page__sustainability-heading {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #4A443E;
    margin-bottom: 14px;
  }
  .product-page__sustainability-cta {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #4A443E;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .product-page__sustainability-body {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.75;
    color: #5C554F;
  }
</style>

<div class="product-page">
  <!-- Gallery — stacked full-bleed images -->
  <div class="product-page__gallery">
    <div class="product-page__gallery-images">
      {%- if product.images.size > 0 -%}
        {%- for image in product.images -%}
          <img class="product-page__gallery-image"
            src="{{ image | image_url: width: 1200 }}"
            alt="{{ product.title | escape }}{% if forloop.index > 1 %} - Image {{ forloop.index }}{% endif %}"
            {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}>
        {%- endfor -%}
      {%- else -%}
        <div class="product-page__gallery-image" style="background: var(--color-bg-warm);"></div>
      {%- endif -%}
    </div>
  </div>

  <!-- Info panel -->
  <div class="product-page__info">
    <div class="product-page__title-row">
      <h1 class="product-page__title">{{ product.title }}</h1>
    </div>

    <div class="product-page__price" id="product-price">
      {%- if product.price_varies -%}
        <span class="product-page__price-from">From</span>
      {%- endif -%}
      {%- if product.compare_at_price > product.price -%}
        <span class="product-page__price-strike">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      <span class="product-page__price-amount">A{{ product.price | money }}</span>
    </div>

    {%- comment -%} Material line {%- endcomment -%}
    <div class="product-page__material">
      {%- if product.metafields.custom.material != blank -%}
        {{ product.metafields.custom.material }}
      {%- else -%}
        Sterling Silver, Lab Grown Moissanite
      {%- endif -%}
    </div>

    {%- comment -%} Color swatches — Silver active, Gold sold out {%- endcomment -%}
    <div class="product-page__swatches">
      <span class="product-page__swatch product-page__swatch--silver is-selected" title="Sterling Silver"></span>
      <span class="product-page__swatch product-page__swatch--gold is-unavailable" title="18ct Gold — Coming Soon"></span>
    </div>

    {%- comment -%} Size/Length variants — hidden for earrings (no sizing needed) {%- endcomment -%}
    {%- assign is_earring = false -%}
    {%- assign h_down = product.handle -%}
    {%- if h_down contains 'earring' or h_down contains 'lumiere' or h_down contains 'picasso' or h_down contains 'quatre' -%}
      {%- assign is_earring = true -%}
    {%- endif -%}
    {%- unless is_earring -%}
      {%- for option in product.options_with_values -%}
        {%- assign opt_down = option.name | downcase -%}
        {%- unless opt_down == 'color' or opt_down == 'colour' or opt_down == 'metal' or opt_down == 'finish' or opt_down == 'metal color' or opt_down == 'metal colour' -%}
          <div class="product-page__variant-group">
            <div class="product-page__variant-header">
              <div class="product-page__variant-label">{{ option.name }}</div>
              {%- if opt_down == 'length' or opt_down == 'size' -%}
                <button type="button" class="product-page__size-guide" id="size-guide-trigger">Size Guide</button>
              {%- endif -%}
            </div>
            <div class="product-page__variant-options" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <button class="product-page__variant-btn{% if option.selected_value == value %} is-selected{% endif %}"
                  data-value="{{ value }}">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    {%- endunless -%}

    {%- comment -%} In Stock {%- endcomment -%}
    {%- if product.available -%}
      <div class="product-page__stock">In Stock &amp; Available to Ship</div>
    {%- endif -%}

    {%- comment -%} Add to bag + wishlist {%- endcomment -%}
    <form action="/cart/add" method="post" id="product-form">
      <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
      <div class="product-page__add-row">
        <button type="submit" class="product-page__add-btn" id="add-to-cart-btn"
          {% unless product.available %}disabled{% endunless %}>
          {%- if product.available -%}
            Add To Bag
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
        <button type="button" class="product-page__wishlist-btn" aria-label="Add to wishlist">
          <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        </button>
      </div>
    </form>

    {%- comment -%} Description — strip spec lines (Stone:, Setting:, Metal:, Length:, Clasp:, Certification:) {%- endcomment -%}
    {%- if product.description != blank -%}
      {%- assign desc_raw = product.description | strip_html -%}
      {%- assign desc_lines = desc_raw | split: '
' -%}
      {%- capture clean_desc -%}
        {%- for line in desc_lines -%}
          {%- assign trimmed = line | strip -%}
          {%- unless trimmed contains 'Stone:' or trimmed contains 'Setting:' or trimmed contains 'Metal:' or trimmed contains 'Length:' or trimmed contains 'Clasp:' or trimmed contains 'Certification:' or trimmed == '' -%}
            {{ trimmed }}
          {%- endunless -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- assign clean_desc = clean_desc | strip -%}
      {%- if clean_desc != blank -%}
        <div class="product-page__description">{{ clean_desc }}</div>
      {%- else -%}
        <div class="product-page__description">Handcrafted in sterling silver featuring lab grown moissanite. These gemstones have the same chemical and physical properties as natural ones — and sparkle just as beautifully.</div>
      {%- endif -%}
    {%- else -%}
      <div class="product-page__description">
        Handcrafted in sterling silver featuring lab grown moissanite. These gemstones have the same chemical and physical properties as natural ones — and sparkle just as beautifully.
      </div>
    {%- endif -%}

    {%- comment -%} Feature icons {%- endcomment -%}
    <div class="product-page__features">
      <div class="product-page__feature">
        <div class="product-page__feature-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
        </div>
        <span class="product-page__feature-text">Hypoallergenic</span>
      </div>
      <div class="product-page__feature">
        <div class="product-page__feature-icon">
          <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
        <span class="product-page__feature-text">Strong & Highly Durable</span>
      </div>
      <div class="product-page__feature">
        <div class="product-page__feature-icon">
          <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <span class="product-page__feature-text">95% Recycled Sterling Silver</span>
      </div>
      <div class="product-page__feature">
        <div class="product-page__feature-icon">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        </div>
        <span class="product-page__feature-text">Ethically Sourced & Conflict-Free</span>
      </div>
    </div>

    {%- comment -%} Accordions — Mejuri style {%- endcomment -%}
    {%- assign handle_down = product.handle -%}
    <div class="product-page__accordions">
      <div class="accordion__item is-open">
        <button class="accordion__trigger">
          <span>Materials</span>
          <span class="accordion__icon">&minus;</span>
        </button>
        <div class="accordion__content" style="max-height:500px;">
          <div class="accordion__content-inner">
            <p style="font-weight:700;text-transform:uppercase;font-size:12px;letter-spacing:0.04em;margin-bottom:8px;">Lab Grown Gemstones</p>
            <p style="margin-bottom:20px;">Our lab grown gemstones share the same physical and chemical properties as natural gemstones. They are valued for their beauty and longevity.</p>
            <p style="font-weight:700;text-transform:uppercase;font-size:12px;letter-spacing:0.04em;margin-bottom:8px;">Sterling Silver</p>
            <p>925 Sterling Silver is a lightweight metal made of 92.5% pure silver. It's highly durable and designed for everyday wear. All of our sterling silver product is made from 95% recycled material.</p>
          </div>
        </div>
      </div>

      <div class="accordion__item">
        <button class="accordion__trigger">
          <span>Specifications</span>
          <span class="accordion__icon">+</span>
        </button>
        <div class="accordion__content">
          <div class="accordion__content-inner">
            {%- comment -%} Pull spec lines from product description if present {%- endcomment -%}
            {%- assign desc_plain = product.description | strip_html -%}
            {%- assign has_desc_specs = false -%}
            {%- if desc_plain contains 'Stone:' or desc_plain contains 'Setting:' or desc_plain contains 'Metal:' or desc_plain contains 'Clasp:' or desc_plain contains 'Certification:' -%}
              {%- assign has_desc_specs = true -%}
            {%- endif -%}
            {%- if has_desc_specs -%}
              <div class="specs-list" id="specs-from-desc">
                {%- assign spec_lines = desc_plain | split: '
' -%}
                {%- for line in spec_lines -%}
                  {%- assign tl = line | strip -%}
                  {%- if tl contains 'Stone:' or tl contains 'Setting:' or tl contains 'Metal:' or tl contains 'Length:' or tl contains 'Clasp:' or tl contains 'Certification:' -%}
                    <p style="margin-bottom:6px;font-size:14px;line-height:1.6;">- {{ tl }}</p>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="specs-table">
                {%- if handle_down contains 'riviere' -%}
                  <div class="specs-table__row"><span class="specs-table__label">Stone Size</span><span>3 mm</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Stone</span><span>D Colour VVS1 Moissanite (40+ stones)</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Setting</span><span>Four-prong tennis link</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Metal</span><span>925 Sterling Silver, rhodium plated</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Lengths</span><span>38cm, 45cm, 56cm</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Certification</span><span>GRA certified — certificate of authenticity included</span></div>
                {%- elsif handle_down contains 'eclat' -%}
                  <div class="specs-table__row"><span class="specs-table__label">Stone</span><span>D Colour VVS1 Moissanite</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Setting</span><span>Four-prong tennis link</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Metal</span><span>925 Sterling Silver, rhodium plated</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Clasp</span><span>Box clasp with safety latch</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Certification</span><span>GRA certified — certificate of authenticity included</span></div>
                {%- elsif handle_down contains 'lumiere' -%}
                  <div class="specs-table__row"><span class="specs-table__label">Stone</span><span>D Colour VVS1 Moissanite</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Setting</span><span>4-Prong Solitaire</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Metal</span><span>925 Sterling Silver, rhodium plated</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Closure</span><span>Butterfly back</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Certification</span><span>GRA certified — certificate of authenticity included</span></div>
                {%- elsif handle_down contains 'eternite' -%}
                  <div class="specs-table__row"><span class="specs-table__label">Stone</span><span>D Colour VVS1 Moissanite</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Setting</span><span>Channel set, full eternity</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Metal</span><span>925 Sterling Silver, rhodium plated</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Certification</span><span>GRA certified — certificate of authenticity included</span></div>
                {%- elsif handle_down contains 'solaire' or handle_down contains 'trefle' -%}
                  <div class="specs-table__row"><span class="specs-table__label">Stone</span><span>D Colour VVS1 Moissanite</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Setting</span><span>Prong set solitaire</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Metal</span><span>925 Sterling Silver, rhodium plated</span></div>
                  <div class="specs-table__row"><span class="specs-table__label">Clasp</span><span>Spring ring clasp</span></div>
