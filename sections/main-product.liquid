<!-- Write a Review Modal -->
<div class="review-modal" id="review-modal">
  <div class="review-modal__overlay" id="review-modal-overlay"></div>
  <div class="review-modal__content">
    <button class="review-modal__close" id="review-modal-close">&times;</button>
    <div id="review-form-wrapper">
      <div class="review-modal__title">Write a Review</div>
      <form id="review-form">
        <div class="review-modal__field">
          <label class="review-modal__label">Rating</label>
          <div class="review-modal__stars-input" id="review-stars-input">
            <button type="button" class="review-modal__star" data-star="1">&#9733;</button>
            <button type="button" class="review-modal__star" data-star="2">&#9733;</button>
            <button type="button" class="review-modal__star" data-star="3">&#9733;</button>
            <button type="button" class="review-modal__star" data-star="4">&#9733;</button>
            <button type="button" class="review-modal__star" data-star="5">&#9733;</button>
          </div>
        </div>
        <div class="review-modal__field">
          <label class="review-modal__label" for="review-name">Name</label>
          <input class="review-modal__input" type="text" id="review-name" placeholder="Your name" required>
        </div>
        <div class="review-modal__field">
          <label class="review-modal__label" for="review-location">Location</label>
          <input class="review-modal__input" type="text" id="review-location" placeholder="City, State">
        </div>
        <div class="review-modal__field">
          <label class="review-modal__label" for="review-text">Review</label>
          <textarea class="review-modal__textarea" id="review-text" placeholder="Share your experience with this piece..." required></textarea>
        </div>
        <div class="review-modal__field">
          <label class="review-modal__label">Photo (Optional)</label>
          <div class="review-modal__drop-zone" id="review-drop-zone">
            <div class="review-modal__drop-text">Drag & drop your photo here or <span>browse</span></div>
            <input type="file" class="review-modal__file-input" id="review-file-input" accept="image/*">
          </div>
          <div class="review-modal__preview" id="review-preview"></div>
        </div>
        <button type="submit" class="review-modal__submit">Submit Review</button>
      </form>
    </div>
    <div class="review-modal__success" id="review-success">
      <div class="review-modal__success-icon">&#10003;</div>
      <div class="review-modal__success-text">Thank you for your review! It will appear after approval.</div>
    </div>
  </div>
</div>

<!-- Photo Lightbox -->
<div class="review-lightbox" id="review-lightbox">
