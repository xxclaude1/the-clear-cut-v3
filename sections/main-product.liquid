        b.classList.remove('is-selected');
      });
      this.classList.add('is-selected');
    });
  });

  /* Color swatch selection — Gold is sold out + 1.3x price */
  var silverPriceText = document.querySelector('.product-page__price-amount');
  var silverPriceOriginal = silverPriceText ? silverPriceText.textContent.trim() : '';
  var goldPriceText = '';
  if (silverPriceOriginal) {
