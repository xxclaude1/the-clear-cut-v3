<style>
  /* ---- Product Page — Wessel-inspired layout ---- */
  .product-page {
    display: grid;
    grid-template-columns: 50% 50%;
    min-height: calc(100vh - var(--header-height) - var(--announcement-height));
  }

  @media (max-width: 768px) {
    .product-page {
      grid-template-columns: 1fr;
    }
  }

  /* Gallery — left half, full bleed, sticky */
  .product-page__gallery {
    position: relative;
    background-color: var(--color-bg-warm);
  }

  @media (min-width: 769px) {
    .product-page__gallery {
      position: sticky;
      top: calc(var(--header-height) + var(--announcement-height));
      height: calc(100vh - var(--header-height) - var(--announcement-height));
      align-self: start;
    }
  }

  .product-page__main-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8%;
  }

  @media (max-width: 768px) {
    .product-page__main-image {
      aspect-ratio: 1 / 1;
      height: auto;
    }
  }

  .product-page__thumbnails {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .product-page__thumbnails {
      position: relative;
      bottom: auto;
      left: auto;
      transform: none;
      padding: 12px 16px;
      background: var(--color-bg-warm);
      gap: 6px;
      justify-content: center;
    }
  }

  .product-page__thumb {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border: 1px solid rgba(0,0,0,0.1);
    cursor: pointer;
    background-color: var(--color-bg);
    padding: 4px;
    transition: border-color var(--duration-fast) ease;
  }

  .product-page__thumb.is-active {
    border: 2px solid var(--color-text);
  }

  .product-page__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Info — right half */
  .product-page__info {
    padding: 48px 48px 80px;
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    .product-page__info {
      padding: 32px 24px 60px;
    }
  }

  @media (max-width: 768px) {
    .product-page__info {
      padding: var(--space-md) var(--page-padding) var(--space-2xl);
    }
  }

  /* Product title — monospace uppercase */
  .product-page__title {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.3;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  /* Description — serif italic editorial */
  .product-page__description {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-text);
    margin-bottom: 28px;
  }

  @media (max-width: 768px) {
    .product-page__description {
      font-size: 16px;
    }
  }

  /* Price — monospace */
  .product-page__price {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 15px;
    letter-spacing: 0.02em;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .product-page__price-strike {
    text-decoration: line-through;
    color: var(--color-text-secondary);
    margin-right: 8px;
  }

  /* Variants */
  .product-page__variant-group {
    margin-bottom: 20px;
  }

  .product-page__variant-label {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: var(--color-text);
  }

  .product-page__variant-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .product-page__variant-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 10px 20px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    cursor: pointer;
    transition: border-color var(--duration-fast) ease;
    line-height: 1;
  }

  .product-page__variant-btn:hover {
    border-color: var(--color-text);
  }

  .product-page__variant-btn.is-selected {
    border: 2px solid var(--color-text);
  }

  .product-page__variant-btn.is-unavailable {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .product-page__size-guide {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-top: 8px;
    display: inline-block;
    transition: opacity var(--duration-fast) ease;
  }

  .product-page__size-guide:hover {
    opacity: 0.6;
  }

  /* Add to cart */
  .product-page__add-form {
    margin-top: 4px;
    margin-bottom: 16px;
  }

  .product-page__add-btn {
    width: 100%;
    height: 52px;
    background-color: var(--color-btn-primary-bg);
    color: var(--color-btn-primary-text);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background-color var(--duration-fast) ease;
  }

  .product-page__add-btn:hover {
    background-color: var(--color-btn-primary-hover);
  }

  .product-page__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Trust line */
  .product-page__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-secondary);
    margin-bottom: 40px;
    letter-spacing: 0.02em;
  }

  .product-page__trust-dot {
    color: var(--color-text-muted);
  }

  /* ---- Specs sections ---- */
  .product-page__specs-section {
    border-top: 1px solid var(--color-border);
    padding-top: 24px;
    margin-bottom: 32px;
  }

  .product-page__specs-heading {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 20px;
    color: var(--color-text);
  }

  .specs-table {
    width: 100%;
  }

  .specs-table__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .specs-table__row:last-child {
    border-bottom: none;
  }

  .specs-table__label {
    color: var(--color-text);
  }

  .specs-table__value {
    color: var(--color-text);
    text-align: right;
  }

  /* ---- Accordion (for mobile or additional sections) ---- */
  .product-page__accordions {
    margin-top: 8px;
  }

  .accordion__item {
    border-top: 1px solid var(--color-border);
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 20px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    text-transform: uppercase;
    color: var(--color-text);
    letter-spacing: 0.06em;
  }

  .accordion__icon {
    font-size: 18px;
    font-weight: 300;
    line-height: 1;
    transition: transform var(--duration-fast) ease;
  }

  .accordion__item.is-open .accordion__icon {
    transform: rotate(45deg);
  }

  .accordion__content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms ease;
  }

  .accordion__content-inner {
    padding: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  /* ---- Reviews section ---- */
  .product-page__reviews {
    padding: var(--space-2xl) var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
    width: 100%;
  }

  .product-page__reviews-heading {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .product-page__reviews-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 1024px) {
    .product-page__reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .product-page__reviews-grid {
      grid-template-columns: 1fr;
    }
  }

  .review-card {
    border: 1px solid var(--color-border);
    padding: 24px;
  }

  .review-card__stars {
    font-size: 14px;
    letter-spacing: 2px;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .review-card__text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 16px;
    font-style: italic;
  }

  .review-card__author {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .review-card__location {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-secondary);
    margin-top: 2px;
  }
</style>

<div class="product-page">
  <!-- Gallery — left half -->
  <div class="product-page__gallery">
    {%- if product.featured_image -%}
      <img class="product-page__main-image" id="main-product-image"
        src="{{ product.featured_image | image_url: width: 1200 }}"
        alt="{{ product.title | escape }}"
        loading="eager">
    {%- else -%}
      <div class="product-page__main-image" style="display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:12px;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-text-muted);">Product Image</div>
    {%- endif -%}

    {%- if product.images.size > 1 -%}
      <div class="product-page__thumbnails">
        {%- for image in product.images limit: 6 -%}
          <button class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
            data-image-url="{{ image | image_url: width: 1200 }}"
            aria-label="View image {{ forloop.index }}">
            <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title | escape }} - Image {{ forloop.index }}" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Info — right half -->
  <div class="product-page__info">
    <h1 class="product-page__title">{{ product.title }}</h1>

    <div class="product-page__description">
      {{ product.description }}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="product-page__thumbnails product-page__thumbnails--inline desktop-only" style="position:relative;bottom:auto;left:auto;transform:none;margin-bottom:24px;justify-content:flex-start;">
        {%- for image in product.images limit: 6 -%}
          <button class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
            data-image-url="{{ image | image_url: width: 1200 }}"
            aria-label="View image {{ forloop.index }}">
            <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title | escape }} - Image {{ forloop.index }}" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="product-page__price" id="product-price">
      {%- if product.compare_at_price > product.price -%}
        <span class="product-page__price-strike">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
      {{ product.price | money }} AUD
    </div>

    {%- for option in product.options_with_values -%}
      <div class="product-page__variant-group">
        <div class="product-page__variant-label">{{ option.name }}: <span id="selected-{{ option.name | handle }}">{{ option.selected_value }}</span></div>
        <div class="product-page__variant-options" data-option-index="{{ forloop.index0 }}">
          {%- for value in option.values -%}
            <button class="product-page__variant-btn{% if option.selected_value == value %} is-selected{% endif %}"
              data-value="{{ value }}">
              {{ value }}
            </button>
          {%- endfor -%}
        </div>
        {%- if option.name == 'Length' or option.name == 'Size' -%}
          <a href="/pages/size-guides" class="product-page__size-guide">Size guide</a>
        {%- endif -%}
      </div>
    {%- endfor -%}

    <form action="/cart/add" method="post" class="product-page__add-form" id="product-form">
      <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="product-page__add-btn" id="add-to-cart-btn"
        {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}
          ADD TO CART
        {%- else -%}
          SOLD OUT
        {%- endif -%}
      </button>
    </form>

    <div class="product-page__trust">
      <span>Free shipping</span>
      <span class="product-page__trust-dot">&middot;</span>
      <span>30-day returns</span>
      <span class="product-page__trust-dot">&middot;</span>
      <span>Lifetime warranty</span>
    </div>

    <!-- Technical Features — open by default like the screenshot -->
    <div class="product-page__specs-section">
      <div class="product-page__specs-heading">Technical Features</div>
      <div class="specs-table">
        <div class="specs-table__row"><span class="specs-table__label">Stone</span><span class="specs-table__value">VVS Moissanite</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Cut</span><span class="specs-table__value">Round Brilliant</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Hardness</span><span class="specs-table__value">9.25 Mohs</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Fire</span><span class="specs-table__value">0.104 (2.4x Diamond)</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Refractive Index</span><span class="specs-table__value">2.65</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Setting</span><span class="specs-table__value">S925 Sterling Silver, 18K Gold Plated</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Closure</span><span class="specs-table__value">Secure Box Clasp</span></div>
      </div>
    </div>

    <!-- Dimensions -->
    <div class="product-page__specs-section">
      <div class="product-page__specs-heading">Dimensions</div>
      <div class="specs-table">
        <div class="specs-table__row"><span class="specs-table__label">Lengths Available</span><span class="specs-table__value">15.5 – 21.5 CM</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Stone Count</span><span class="specs-table__value">40 Stones</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Stone Size</span><span class="specs-table__value">3mm Round</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Width</span><span class="specs-table__value">3mm</span></div>
        <div class="specs-table__row"><span class="specs-table__label">Weight</span><span class="specs-table__value">~8g</span></div>
      </div>
    </div>

    <!-- Accordion sections -->
    <div class="product-page__accordions">
      <div class="accordion__item">
        <button class="accordion__trigger">
          <span>Shipping & Returns</span>
          <span class="accordion__icon">+</span>
        </button>
        <div class="accordion__content">
          <div class="accordion__content-inner">
            Free express shipping on all Australian orders via Australia Post. Typical delivery: 2-5 business days with full tracking. 30-day return window from date of delivery. Items must be unworn and in original packaging. Free return shipping within Australia.
          </div>
        </div>
      </div>

      <div class="accordion__item" style="border-bottom: 1px solid var(--color-border);">
        <button class="accordion__trigger">
          <span>Care Guide</span>
          <span class="accordion__icon">+</span>
        </button>
        <div class="accordion__content">
          <div class="accordion__content-inner">
            Clean with warm soapy water and a soft brush. Avoid harsh chemicals, chlorine, and abrasive surfaces. Store in the provided jewelry box when not wearing. Polish gently with the included microfiber cloth.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Reviews Section -->
<section class="product-page__reviews reveal">
  <div class="product-page__reviews-heading">What Our Customers Say</div>
  <div class="product-page__reviews-grid">
    <div class="review-card">
      <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <p class="review-card__text">"I've received more compliments on this bracelet than any piece of jewelry I own. The sparkle is unreal."</p>
      <div class="review-card__author">Sarah M.</div>
      <div class="review-card__location">Sydney</div>
    </div>
    <div class="review-card">
      <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <p class="review-card__text">"My partner thought it was a diamond. The quality exceeded every expectation."</p>
      <div class="review-card__author">Emma L.</div>
      <div class="review-card__location">Melbourne</div>
    </div>
    <div class="review-card">
      <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <p class="review-card__text">"Arrived beautifully packaged with a certificate of authenticity. Truly premium."</p>
      <div class="review-card__author">Jessica K.</div>
      <div class="review-card__location">Brisbane</div>
    </div>
    <div class="review-card">
      <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
      <p class="review-card__text">"I was skeptical about moissanite but this completely changed my mind. Stunning."</p>
      <div class="review-card__author">Lauren T.</div>
      <div class="review-card__location">Perth</div>
    </div>
  </div>
</section>

<script>
  /* Thumbnail click handler */
  document.querySelectorAll('.product-page__thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = this.getAttribute('data-image-url');
      if (url) {
        document.getElementById('main-product-image').src = url;
      }
      document.querySelectorAll('.product-page__thumb').forEach(function(t) {
        t.classList.remove('is-active');
      });
      /* Highlight all thumbs with same url (inline + overlay) */
      document.querySelectorAll('.product-page__thumb[data-image-url="' + url + '"]').forEach(function(t) {
        t.classList.add('is-active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
