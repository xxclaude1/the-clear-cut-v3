      {n:"Jessica K.",l:"Brisbane",r:5,d:"2025-11-18",t:"I was skeptical about moissanite but this completely changed my mind. The craftsmanship is exceptional.",v:true},
      {n:"Lauren T.",l:"Perth",r:5,d:"2025-12-22",t:"Free shipping, lifetime warranty, and the piece itself is gorgeous. Can't ask for more than that.",v:true}
    ]
  };

  /* ============ REVIEW ENGINE ============ */
  var handle = document.getElementById('reviews-section').dataset.handle;
  var reviews = reviewData[handle] || reviewData['_default'];
  var perPage = window.innerWidth <= 768 ? 3 : 8;
  var currentPage = 1;
  var currentSort = 'recent';

  function getStars(count) {
    var s = '';
    for (var i = 0; i < 5; i++) s += i < count ? '\u2605' : '\u2606';
    return s;
  }

  function formatDate(ds) {
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var parts = ds.split('-');
    return months[parseInt(parts[1], 10) - 1] + ' ' + parseInt(parts[2], 10) + ', ' + parts[0];
  }

  function computeStats() {
    var total = reviews.length;
    var sum = 0;
    var counts = {5:0, 4:0, 3:0, 2:0, 1:0};
    reviews.forEach(function(r) { sum += r.r; counts[r.r]++; });
    var avg = total > 0 ? (sum / total).toFixed(1) : '0.0';
    return {total: total, avg: avg, counts: counts};
  }

  function renderSummary() {
    var stats = computeStats();
    document.getElementById('reviews-average').textContent = stats.avg;
    document.getElementById('reviews-summary-stars').innerHTML = getStars(Math.round(parseFloat(stats.avg)));
    document.getElementById('reviews-summary-count').textContent = 'Based on ' + stats.total + ' review' + (stats.total !== 1 ? 's' : '');
    var breakdownEl = document.getElementById('reviews-breakdown');
    var html = '';
    for (var i = 5; i >= 1; i--) {
      var pct = stats.total > 0 ? ((stats.counts[i] / stats.total) * 100).toFixed(0) : 0;
      html += '<div class="reviews__breakdown-row">' +
        '<span class="reviews__breakdown-label">' + i + ' \u2605</span>' +
        '<div class="reviews__breakdown-bar"><div class="reviews__breakdown-fill" style="width:' + pct + '%"></div></div>' +
        '<span class="reviews__breakdown-count">' + stats.counts[i] + '</span></div>';
    }
    breakdownEl.innerHTML = html;
  }

  function renderPhotos() {
    var photoReviews = reviews.filter(function(r) { return r.p; });
    if (photoReviews.length === 0) return;
    document.getElementById('reviews-photos').style.display = 'block';
    var scrollEl = document.getElementById('reviews-photos-scroll');
    scrollEl.innerHTML = photoReviews.map(function(r) {
      return '<img class="reviews__photo-thumb" src="' + r.p + '" alt="Customer photo by ' + r.n + '" loading="lazy" onclick="openLightbox(this.src)">';
    }).join('');
  }

  function getSortedReviews() {
    var sorted = reviews.slice();
    if (currentSort === 'recent') {
      sorted.sort(function(a, b) { return b.d.localeCompare(a.d); });
    } else if (currentSort === 'highest') {
      sorted.sort(function(a, b) { return b.r - a.r || b.d.localeCompare(a.d); });
    } else if (currentSort === 'photos') {
      sorted.sort(function(a, b) { return (b.p ? 1 : 0) - (a.p ? 1 : 0) || b.d.localeCompare(a.d); });
    }
    return sorted;
  }

  function renderReviews() {
    var sorted = getSortedReviews();
    var visible = sorted.slice(0, currentPage * perPage);
    var gridEl = document.getElementById('reviews-grid');
    gridEl.innerHTML = visible.map(function(r) {
      var card = '<div class="review-card">' +
        '<div class="review-card__top">' +
          '<div class="review-card__stars">' + getStars(r.r) + '</div>' +
          '<div class="review-card__date">' + formatDate(r.d) + '</div>' +
        '</div>' +
        '<div class="review-card__text">' + r.t + '</div>';
      if (r.p) {
        card += '<img class="review-card__photo" src="' + r.p + '" alt="Review photo" loading="lazy" onclick="openLightbox(this.src)">';
      }
      card += '<div class="review-card__footer">' +
        '<div class="review-card__author-info">' +
          '<div class="review-card__author">' + r.n + '</div>' +
          '<div class="review-card__location">' + r.l + '</div>' +
        '</div>' +
        '<div class="review-card__meta">';
      if (r.v) {
        card += '<div class="review-card__verified"><svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>Verified</div>';
      }
      if (r.s) {
        card += '<div class="review-card__variant">Purchased: ' + r.s + '</div>';
      }
      card += '</div></div></div>';
      return card;
    }).join('');

    var showMoreEl = document.getElementById('reviews-show-more');
    if (visible.length < sorted.length) {
      showMoreEl.style.display = 'flex';
    } else {
      showMoreEl.style.display = 'none';
    }
  }

  /* Sort handler */
  document.getElementById('reviews-sort').addEventListener('change', function() {
    currentSort = this.value;
    currentPage = 1;
    renderReviews();
  });

  /* Show more handler */
  document.getElementById('reviews-show-more-btn').addEventListener('click', function() {
    currentPage++;
    renderReviews();
  });

  /* ============ MODAL ============ */
  var modal = document.getElementById('review-modal');
  var formRating = 0;

  document.getElementById('reviews-write-btn').addEventListener('click', function() {
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  });

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.getElementById('review-modal-close').addEventListener('click', closeModal);
  document.getElementById('review-modal-overlay').addEventListener('click', closeModal);

  /* Star rating input */
  document.querySelectorAll('.review-modal__star').forEach(function(star) {
    star.addEventListener('click', function() {
      formRating = parseInt(this.dataset.star);
      document.querySelectorAll('.review-modal__star').forEach(function(s) {
        s.classList.toggle('is-active', parseInt(s.dataset.star) <= formRating);
      });
    });
  });

  /* Drag & drop */
  var dropZone = document.getElementById('review-drop-zone');
  var fileInput = document.getElementById('review-file-input');
  var previewEl = document.getElementById('review-preview');

  dropZone.addEventListener('click', function() { fileInput.click(); });
  dropZone.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('is-dragover'); });
  dropZone.addEventListener('dragleave', function() { this.classList.remove('is-dragover'); });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    this.classList.remove('is-dragover');
    handleFiles(e.dataTransfer.files);
  });
  fileInput.addEventListener('change', function() { handleFiles(this.files); });

  function handleFiles(files) {
    previewEl.innerHTML = '';
    Array.from(files).forEach(function(file) {
      if (!file.type.startsWith('image/')) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = document.createElement('img');
        img.className = 'review-modal__preview-img';
        img.src = e.target.result;
        previewEl.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  }

  /* Form submit */
  document.getElementById('review-form').addEventListener('submit', function(e) {
    e.preventDefault();
    document.getElementById('review-form-wrapper').style.display = 'none';
    document.getElementById('review-success').classList.add('is-visible');
    setTimeout(function() {
      closeModal();
      document.getElementById('review-form-wrapper').style.display = '';
      document.getElementById('review-success').classList.remove('is-visible');
      e.target.reset();
      previewEl.innerHTML = '';
      formRating = 0;
      document.querySelectorAll('.review-modal__star').forEach(function(s) { s.classList.remove('is-active'); });
    }, 3000);
  });

  /* ============ LIGHTBOX ============ */
  window.openLightbox = function(src) {
    var lb = document.getElementById('review-lightbox');
    document.getElementById('review-lightbox-img').src = src;
    lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };

  document.getElementById('review-lightbox-close').addEventListener('click', function() {
    document.getElementById('review-lightbox').classList.remove('is-open');
    document.body.style.overflow = '';
  });

  document.getElementById('review-lightbox').addEventListener('click', function(e) {
    if (e.target === this) {
      this.classList.remove('is-open');
      document.body.style.overflow = '';
    }
  });

  /* ============ SIZE GUIDE MODAL ============ */
  var sgModal = document.getElementById('size-guide-modal');
  var sgTrigger = document.getElementById('size-guide-trigger');
  var productHandle = handle;

  var sizeGuideData = {
    necklace: {
      title: 'Necklace Size Guide',
      chart: '<table class="size-guide-modal__table"><tr><th>Inches (in)</th><th>Centimetres (cm)</th></tr><tr><td>15"</td><td>38 cm</td></tr><tr><td>18"</td><td>45 cm</td></tr><tr><td>22"</td><td>56 cm</td></tr></table>',
      style: '<div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">38cm (15")</div><div class="size-guide-modal__style-desc">Sits high on the neck, often referred to as a choker length. Style solo or layer with longer necklaces for a statement stack.</div></div><div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">45cm (18")</div><div class="size-guide-modal__style-desc">One of the most common necklace lengths, designed to fall on or below the base of the neck. A versatile length perfect for pairing with your favourite charms and pendants.</div></div><div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">56cm (22")</div><div class="size-guide-modal__style-desc">A longer necklace designed to sit just above the chest. Plays perfectly with open necklines, added necklace layers, and personalised pendant stacks.</div></div>'
    },
    bracelet: {
      title: 'Bracelet Size Guide',
      chart: '<table class="size-guide-modal__table"><tr><th>Size</th><th>Centimetres (cm)</th></tr><tr><td>Small</td><td>15.5 cm</td></tr><tr><td>Medium</td><td>16.5 cm</td></tr><tr><td>Standard</td><td>18 cm</td></tr><tr><td>Large</td><td>19 cm</td></tr><tr><td>X-Large</td><td>20.5 cm</td></tr></table>',
      style: '<div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">15.5cm - 16.5cm</div><div class="size-guide-modal__style-desc">A snug fit that sits close to the wrist. Best for smaller wrists or those who prefer a tighter bracelet.</div></div><div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">18cm (Standard)</div><div class="size-guide-modal__style-desc">The most popular length. Fits comfortably with a little movement. Works for most wrist sizes.</div></div><div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">19cm - 21.5cm</div><div class="size-guide-modal__style-desc">A relaxed, looser fit. Great for larger wrists or if you prefer your bracelet to drape rather than hug.</div></div>'
    },
    ring: {
      title: 'Ring Size Guide',
      chart: '<table class="size-guide-modal__table"><tr><th>AU/UK Size</th><th>US Size</th><th>Diameter (mm)</th></tr><tr><td>H</td><td>4</td><td>14.9</td></tr><tr><td>J</td><td>5</td><td>15.7</td></tr><tr><td>L</td><td>6</td><td>16.5</td></tr><tr><td>N</td><td>7</td><td>17.3</td></tr><tr><td>P</td><td>8</td><td>18.1</td></tr><tr><td>R</td><td>9</td><td>18.9</td></tr></table>',
      style: '<div class="size-guide-modal__style-item"><div class="size-guide-modal__style-size">How to Measure</div><div class="size-guide-modal__style-desc">Wrap a thin strip of paper around your finger. Mark where it overlaps and measure the length in mm. Compare to the diameter column above. For a comfortable fit, measure at the end of the day when fingers are at their largest.</div></div>'
    },
    earring: null
  };

  function getProductType() {
    if (productHandle.indexOf('bracelet') !== -1 || productHandle.indexOf('eclat') !== -1) return 'bracelet';
    if (productHandle.indexOf('band') !== -1 || productHandle.indexOf('eternite') !== -1) return 'ring';
    if (productHandle.indexOf('earring') !== -1 || productHandle.indexOf('hoop') !== -1 || productHandle.indexOf('lumiere') !== -1 || productHandle.indexOf('picasso') !== -1 || productHandle.indexOf('quatre') !== -1) return 'earring';
    return 'necklace';
  }

  function openSizeGuide() {
    var type = getProductType();
    var data = sizeGuideData[type];
    if (!data) return;
    document.getElementById('size-guide-title').textContent = data.title;
    document.getElementById('sg-panel-chart').innerHTML = data.chart;
    document.getElementById('sg-panel-style').innerHTML = data.style;
    sgModal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  if (sgTrigger) sgTrigger.addEventListener('click', openSizeGuide);

  document.getElementById('size-guide-close').addEventListener('click', function() {
    sgModal.classList.remove('is-open');
    document.body.style.overflow = '';
  });
  document.getElementById('size-guide-overlay').addEventListener('click', function() {
    sgModal.classList.remove('is-open');
    document.body.style.overflow = '';
  });

  document.querySelectorAll('.size-guide-modal__tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.size-guide-modal__tab').forEach(function(t) { t.classList.remove('is-active'); });
      document.querySelectorAll('.size-guide-modal__panel').forEach(function(p) { p.classList.remove('is-active'); });
      this.classList.add('is-active');
      document.getElementById('sg-panel-' + this.dataset.tab).classList.add('is-active');
    });
  });

  /* ============ YOU MAY ALSO LIKE — SLIDER ============ */
  var relatedEl = document.getElementById('related-products');
  if (relatedEl && window.__relatedProducts && window.__relatedProducts.length > 0) {
    relatedEl.innerHTML = window.__relatedProducts.map(function(p) {
      return '<a class="related__card" href="' + p.url + '">' +
        (p.img ? '<img class="related__card-img" src="' + p.img + '" alt="' + p.title + '" loading="lazy">' : '<div class="related__card-img"></div>') +
        '<div class="related__card-info">' +
          '<div class="related__card-name">' + p.title + '</div>' +
          '<div class="related__card-price">' + p.price + '</div>' +
          '<div class="related__card-material">Sterling Silver, Lab Grown Moissanite</div>' +
        '</div></a>';
    }).join('');

    var prevBtn = document.getElementById('related-prev');
    var nextBtn = document.getElementById('related-next');
    if (prevBtn) prevBtn.addEventListener('click', function() {
      relatedEl.scrollBy({ left: -300, behavior: 'smooth' });
    });
    if (nextBtn) nextBtn.addEventListener('click', function() {
      relatedEl.scrollBy({ left: 300, behavior: 'smooth' });
    });
  }

  /* ============ ACCORDION ICON TOGGLE ============ */
  document.querySelectorAll('.accordion__trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      setTimeout(function() {
        document.querySelectorAll('.accordion__item').forEach(function(item) {
          var icon = item.querySelector('.accordion__icon');
          if (icon) icon.innerHTML = item.classList.contains('is-open') ? '&minus;' : '+';
        });
      }, 10);
    });
  });

  /* ============ INIT ============ */
  renderSummary();
  renderPhotos();
  renderReviews();
})();
</script>

