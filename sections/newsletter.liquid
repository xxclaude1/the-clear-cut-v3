<style>
  .newsletter {
    background-color: #E8E4DE;
    padding: 24px var(--page-padding);
  }

  .newsletter__inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .newsletter__text {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .newsletter__badge {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4A443E;
    white-space: nowrap;
  }

  .newsletter__separator {
    color: #9A9189;
    font-weight: 300;
    font-size: 14px;
  }

  .newsletter__label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #6B6360;
    white-space: nowrap;
  }

  .newsletter__form {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .newsletter__input {
    font-family: var(--font-body);
    font-size: 12px;
    color: #4A443E;
    background: transparent;
    border: none;
    border-bottom: 1px solid #9A9189;
    padding: 6px 0;
    width: 200px;
    outline: none;
    letter-spacing: 0.02em;
    transition: border-color 200ms ease;
  }

  .newsletter__input::placeholder {
    color: #9A9189;
  }

  .newsletter__input:focus {
    border-color: #4A443E;
  }

  .newsletter__submit {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4A443E;
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding: 6px 0 6px 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 200ms ease;
  }

  .newsletter__submit:hover {
    opacity: 0.6;
  }

  .newsletter__success {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: #4A443E;
    letter-spacing: 0.03em;
    display: none;
  }

  .newsletter__form.is-success .newsletter__success {
    display: block;
  }

  .newsletter__form.is-success .newsletter__input,
  .newsletter__form.is-success .newsletter__submit {
    display: none;
  }

  @media (max-width: 768px) {
    .newsletter {
      padding: 20px var(--page-padding);
    }

    .newsletter__inner {
      gap: 12px;
    }

    .newsletter__input {
      width: 150px;
    }
  }
</style>

<section class="newsletter">
  <div class="newsletter__inner">
    <div class="newsletter__text">
      <span class="newsletter__badge">{{ section.settings.badge | default: 'THE CLEAR CUT+' }}</span>
      <span class="newsletter__separator">|</span>
      <span class="newsletter__label">Become a Member</span>
    </div>
    <div class="newsletter__form" id="newsletter-form">
      <input
        type="email"
        class="newsletter__input"
        id="newsletter-email"
        placeholder="Enter your email"
        required
        autocomplete="email"
      >
      <button type="button" class="newsletter__submit" id="newsletter-submit">Join</button>
      <span class="newsletter__success">Welcome to The Clear Cut+</span>
    </div>
  </div>
</section>

<script>
  (function() {
    var form = document.getElementById('newsletter-form');
    var input = document.getElementById('newsletter-email');
    var btn = document.getElementById('newsletter-submit');

    btn.addEventListener('click', function() {
      var email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        input.focus();
        return;
      }

      btn.textContent = '...';
      btn.disabled = true;

      // Submit to Shopify's customer API to store the email as a newsletter subscriber
      fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'form_type=customer&utf8=%E2%9C%93&contact%5Bemail%5D=' + encodeURIComponent(email) + '&contact%5Btags%5D=newsletter%2Cclear-cut-plus'
      }).then(function() {
        form.classList.add('is-success');
      }).catch(function() {
        form.classList.add('is-success');
      });
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        btn.click();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge text", "default": "THE CLEAR CUT+" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Join The Clear Cut+ for free and discover exclusive access to our biggest drops, promotions, members-only products, and more." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Join Now For Free" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
