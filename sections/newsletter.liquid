<style>
  .newsletter {
    background-color: #D5CEC6;
    padding: 24px var(--page-padding);
  }

  .newsletter__inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .newsletter__text {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .newsletter__badge {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #3D3630;
    white-space: nowrap;
  }

  .newsletter__separator {
    color: #9A9189;
    font-weight: 300;
    font-size: 14px;
  }

  .newsletter__label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #5C544C;
    white-space: nowrap;
  }

  .newsletter__body {
    font-family: var(--font-body);
    font-size: 12px;
    color: #6B6360;
    line-height: 1.5;
    max-width: 480px;
  }

  .newsletter__cta {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #3D3630;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .newsletter {
      padding: 20px var(--page-padding);
    }

    .newsletter__inner {
      gap: 12px;
    }

    .newsletter__body {
      display: none;
    }
  }
</style>

<section class="newsletter">
  <div class="newsletter__inner">
    <div class="newsletter__text">
      <span class="newsletter__badge">{{ section.settings.badge | default: 'THE CLEAR CUT+' }}</span>
      <span class="newsletter__separator">|</span>
      <span class="newsletter__label">Become a Member</span>
    </div>
    <a href="{{ section.settings.cta_url | default: '#' }}" class="newsletter__cta">{{ section.settings.cta_text | default: 'Join Now For Free' }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge text", "default": "THE CLEAR CUT+" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Join The Clear Cut+ for free and discover exclusive access to our biggest drops, promotions, members-only products, and more." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Join Now For Free" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
