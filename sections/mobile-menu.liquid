<style>
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--color-bg);
    z-index: 300;
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__close {
    position: absolute;
    top: 18px;
    right: var(--page-padding);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--color-text);
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 300ms ease 200ms, transform 300ms ease 200ms;
    z-index: 1;
  }

  .mobile-menu.is-open .mobile-menu__close {
    opacity: 1;
    transform: scale(1);
  }

  .mobile-menu__close svg {
    width: 22px;
    height: 22px;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .mobile-menu__link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 22px;
    text-transform: uppercase;
    color: var(--color-text);
    letter-spacing: 0.06em;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 500ms cubic-bezier(0.16, 1, 0.3, 1),
                transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu__link:active {
    opacity: 0.5;
  }

  .mobile-menu.is-open .mobile-menu__link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu.is-open .mobile-menu__link:nth-child(1) { transition-delay: 100ms; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(2) { transition-delay: 160ms; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(3) { transition-delay: 220ms; }
  .mobile-menu.is-open .mobile-menu__link:nth-child(4) { transition-delay: 280ms; }

  .mobile-menu__bottom {
    position: absolute;
    bottom: 40px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 24px;
    opacity: 0;
    transition: opacity 400ms ease 350ms;
  }

  .mobile-menu.is-open .mobile-menu__bottom {
    opacity: 1;
  }

  .mobile-menu__bottom-link {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--duration-fast) ease;
  }

  .mobile-menu__bottom-link:hover {
    color: var(--color-text);
  }
</style>

<div class="mobile-menu" role="dialog" aria-label="Navigation menu">
  <button class="mobile-menu__close" data-menu-close aria-label="Close menu">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="4" y1="4" x2="16" y2="16"></line>
      <line x1="16" y1="4" x2="4" y2="16"></line>
    </svg>
  </button>

  <nav class="mobile-menu__nav" role="navigation">
    <a href="/collections/all-jewelry" class="mobile-menu__link">All Jewelry</a>
    <a href="/collections/new-in" class="mobile-menu__link">New In</a>
    <a href="/collections" class="mobile-menu__link">Collections</a>
    <a href="/pages/materials" class="mobile-menu__link">Materials</a>
  </nav>

  <div class="mobile-menu__bottom">
    <a href="/search" class="mobile-menu__bottom-link">Search</a>
    <a href="/account" class="mobile-menu__bottom-link">Account</a>
  </div>
</div>

{% schema %}
{
  "name": "Mobile Menu",
  "settings": []
}
{% endschema %}
