<style>
  .cart-drawer__overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-overlay);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 250ms ease;
  }

  .cart-drawer.is-open .cart-drawer__overlay {
    opacity: 1;
    pointer-events: auto;
  }

  .cart-drawer__panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    height: 100vh;
    background-color: var(--color-bg);
    z-index: 200;
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-out);
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .cart-drawer__panel {
      width: 100%;
    }
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-drawer__title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text);
  }

  .cart-drawer__close svg {
    width: 20px;
    height: 20px;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }

  .cart-drawer__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-text-secondary);
  }

  /* Cart item */
  .cart-item {
    display: flex;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-item__image {
    width: 80px;
    height: 80px;
    background-color: var(--color-bg-warm);
    flex-shrink: 0;
  }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart-item__name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .cart-item__variant {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .cart-item__quantity {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
  }

  .cart-item__qty-btn {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    background: none;
    cursor: pointer;
    font-size: 14px;
  }

  .cart-item__qty-value {
    font-family: var(--font-body);
    font-size: 14px;
    min-width: 20px;
    text-align: center;
  }

  .cart-item__price {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    margin-top: auto;
    text-align: right;
  }

  .cart-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    font-size: 12px;
    padding: 0;
    transition: color var(--duration-fast) ease;
  }

  .cart-item__remove:hover {
    color: var(--color-text);
  }

  /* Footer */
  .cart-drawer__footer {
    padding: 20px 24px;
    border-top: 1px solid var(--color-border);
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .cart-drawer__subtotal-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
  }

  .cart-drawer__subtotal-price {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
  }

  .cart-drawer__checkout {
    width: 100%;
    margin-bottom: 8px;
  }

  .cart-drawer__shipping-note {
    text-align: center;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-secondary);
  }
</style>

<div class="cart-drawer" aria-label="Shopping cart">
  <div class="cart-drawer__overlay" data-cart-close></div>

  <div class="cart-drawer__panel" role="dialog">
    <div class="cart-drawer__header">
      <span class="cart-drawer__title">Your Cart ({{ cart.item_count }})</span>
      <button class="cart-drawer__close" data-cart-close aria-label="Close cart">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="4" y1="4" x2="16" y2="16"></line>
          <line x1="16" y1="4" x2="4" y2="16"></line>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__body">
      {%- if cart.item_count == 0 -%}
        <div class="cart-drawer__empty">Your cart is empty.</div>
      {%- else -%}
        {%- for item in cart.items -%}
          <div class="cart-item">
            <div class="cart-item__image">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="cart-item__details">
              <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
              <span class="cart-item__variant">{{ item.variant.title }}</span>
              <div class="cart-item__quantity">
                <button class="cart-item__qty-btn" aria-label="Decrease quantity">−</button>
                <span class="cart-item__qty-value">{{ item.quantity }}</span>
                <button class="cart-item__qty-btn" aria-label="Increase quantity">+</button>
              </div>
            </div>
            <div>
              <div class="cart-item__price">{{ item.final_line_price | money }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span class="cart-drawer__subtotal-label">Subtotal</span>
          <span class="cart-drawer__subtotal-price">{{ cart.total_price | money }}</span>
        </div>
        <a href="/checkout" class="btn-primary btn-primary--full cart-drawer__checkout">Check Out</a>
        <p class="cart-drawer__shipping-note">Shipping calculated at checkout.</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
