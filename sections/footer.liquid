<style>
  .footer {
    border-top: 1px solid var(--color-border);
  }

  .footer__content {
    padding: 64px var(--page-padding);
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .footer__content {
      grid-template-columns: repeat(2, 1fr);
      padding: 40px var(--page-padding);
      gap: var(--space-md);
    }
  }

  .footer__column-heading {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    line-height: 1;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__link {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    transition: opacity var(--duration-fast) ease;
  }

  .footer__link:hover {
    opacity: 0.6;
  }

  /* Bottom bar */
  .footer__bar {
    background-color: var(--color-footer-bar-bg);
    color: var(--color-footer-bar-text);
    padding: 24px var(--page-padding);
  }

  .footer__bar-inner {
    max-width: var(--page-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer__bar-locale {
    font-family: var(--font-body);
    font-size: 12px;
    opacity: 0.8;
  }

  .footer__bar-legal {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .footer__bar-legal a,
  .footer__bar-copyright {
    font-family: var(--font-body);
    font-size: 12px;
    opacity: 0.8;
    transition: opacity var(--duration-fast) ease;
  }

  .footer__bar-legal a:hover {
    opacity: 1;
  }

  .footer__bar-social {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer__bar-social a {
    opacity: 0.8;
    transition: opacity var(--duration-fast) ease;
  }

  .footer__bar-social a:hover {
    opacity: 1;
  }

  .footer__bar-social svg {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 768px) {
    .footer__bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>

<footer class="footer" role="contentinfo">
  <div class="footer__content">
    <!-- Help -->
    <div class="footer__column">
      <h4 class="footer__column-heading">Help</h4>
      <div class="footer__links">
        <a href="/pages/faq" class="footer__link">FAQs</a>
        <a href="/pages/shipping" class="footer__link">Shipping & Delivery</a>
        <a href="/pages/returns" class="footer__link">Returns & Exchanges</a>
        <a href="/pages/warranty" class="footer__link">Warranty</a>
        <a href="/pages/contact" class="footer__link">Contact Us</a>
      </div>
    </div>

    <!-- Resources -->
    <div class="footer__column">
      <h4 class="footer__column-heading">Resources</h4>
      <div class="footer__links">
        <a href="/pages/jewelry-care" class="footer__link">Jewelry Care</a>
        <a href="/pages/size-guide" class="footer__link">Size Guide</a>
        <a href="/pages/materials" class="footer__link">Our Materials</a>
        <a href="/pages/certification" class="footer__link">GRA Certification</a>
      </div>
    </div>

    <!-- About -->
    <div class="footer__column">
      <h4 class="footer__column-heading">About The Clear Cut</h4>
      <div class="footer__links">
        <a href="/pages/about" class="footer__link">Our Mission</a>
        <a href="/pages/sustainability" class="footer__link">Sustainability</a>
        <a href="/pages/careers" class="footer__link">Careers</a>
      </div>
    </div>

    <!-- Shop -->
    <div class="footer__column">
      <h4 class="footer__column-heading">Shop</h4>
      <div class="footer__links">
        <a href="/collections/all-jewelry" class="footer__link">All Jewelry</a>
        <a href="/collections/earrings" class="footer__link">Earrings</a>
        <a href="/collections/necklaces" class="footer__link">Necklaces</a>
        <a href="/collections/bracelets" class="footer__link">Bracelets</a>
        <a href="/collections/rings" class="footer__link">Rings</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bar">
    <div class="footer__bar-inner">
      <span class="footer__bar-locale">Country & Language: 🌐 Australia (AUD) | English</span>

      <div class="footer__bar-legal">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms And Conditions</a>
        <span class="footer__bar-copyright">&copy; {{ 'now' | date: '%Y' }} The Clear Cut</span>
      </div>

      <div class="footer__bar-social">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
