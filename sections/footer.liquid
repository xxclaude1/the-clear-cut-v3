        {%- endif -%}
        {%- if settings.social_pinterest != blank -%}
          <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.582 0 0 3.582 0 8c0 3.39 2.108 6.285 5.084 7.45-.07-.633-.134-1.608.028-2.3.146-.625.944-4.003.944-4.003s-.24-.482-.24-1.194c0-1.118.648-1.953 1.456-1.953.687 0 1.018.515 1.018 1.133 0 .69-.44 1.722-.666 2.678-.19.8.4 1.452 1.188 1.452 1.426 0 2.522-1.503 2.522-3.672 0-1.919-1.38-3.26-3.35-3.26-2.282 0-3.621 1.713-3.621 3.483 0 .69.265 1.428.596 1.83a.24.24 0 01.056.23c-.061.252-.196.8-.222.912-.035.147-.115.178-.266.107-.99-.46-1.61-1.908-1.61-3.07 0-2.5 1.815-4.795 5.232-4.795 2.747 0 4.883 1.957 4.883 4.573 0 2.73-1.72 4.928-4.109 4.928-.803 0-1.557-.417-1.814-.91l-.493 1.882c-.179.688-.662 1.55-.986 2.075C6.375 15.844 7.17 16 8 16c4.418 0 8-3.582 8-8s-3.582-8-8-8z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter != blank -%}
          <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M12.6.75h2.454l-5.36 6.126L16 15.25h-4.937l-3.867-5.056-4.425 5.056H.316l5.733-6.554L0 .75h5.063l3.495 4.622L12.6.75zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

